@model ChecklistForm.Models.PartsViewModel
@{
    ViewBag.Title = "Parts";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    Html.RenderPartial("_ErrorMessage");
}


@using (Html.BeginForm("Parts", "IpqcFroms", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true)


    <div class="box box-solid box-warning">
        <div class="box-header">
            @*<h3 class="box-title">Create New ID</h3*@>
            <div class="box-tools pull-right">
                <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                    <i class="fa fa-minus"></i>
                </button>
            </div>
        </div><!-- /.box-header -->
        <div class="box-body">

            <div class="register-box">
                <div class="register-logo">
                    <a href="#"><b>Parts Creation </b></a>
                </div>

                <div class="register-box-body">
                    @*<p class="login-box-msg">Register a new membership</p>*@

                    <form action=".." method="post">
                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(model => model.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "Select ProjectName", new { @class = "form-control select2", @style = "width: 100%", onchange = "ddlProjectsChanged()", required = "required" })<br />
                            @Html.ValidationMessageFor(model => model.ProjectId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>
                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(model => model.MachineId, new SelectList(Model.Machines, "MachineId", "MachineName", 0), "Select MachineName", new { @class = "form-control select2", @style = "width: 100%", onchange = "ddlMachinesChanged()", required = "required" })<br />
                            @Html.ValidationMessageFor(model => model.MachineId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>
                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(model => model.CatId, new SelectList(Model.Categories, "CatId", "Category", 0), "Select Category", new { @class = "form-control select2", @style = "width: 100%", onchange = "ddlCategoriesChanged()", required = "required" })<br />
                            @Html.ValidationMessageFor(model => model.ActivityId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>
                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(model => model.ActivityId, new SelectList(Model.Activities, "ActivityId", "Activity", 0), "Select Activity", new { @class = "form-control select2", @style = "width: 100%", required = "required" })
                            @Html.ValidationMessageFor(model => model.ActivityId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>
                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.Sno, new { placeholder = "Sno", @class = "form-control", autocomplete = "off", @required = "true" })
                            @Html.ValidationMessageFor(model => model.Sno, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>
                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.PartOfInspection, new { placeholder = "PartOfInspection", @class = "form-control", autocomplete = "off",@required="true" })
                            @Html.ValidationMessageFor(model => model.PartOfInspection, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.Freq, new { placeholder = "Frequency", @class = "form-control", autocomplete = "off", @required = "true" })
                            @Html.ValidationMessageFor(model => model.Freq, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.StandardCondition, new { placeholder = "StandardCondition", @class = "form-control", autocomplete = "off", @required = "true" })
                            @Html.ValidationMessageFor(model => model.StandardCondition, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        <div class="row">
                            <div class="col-xs-4">

                            </div>
                            <div class="col-xs-4">
                                <button type="submit" class="btn btn-success btn-block btn-flat">Submit</button>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-4">

                            </div>
                            <!-- /.col -->
                        </div>
                        <div class="row">
                            <div class="col-xs-2">

                            </div>
                            <div class="col-xs-8">
                                <h3 class="text-danger">@ViewBag.ResultMessage</h3>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-2">

                            </div>
                            <!-- /.col -->
                        </div>
                    </form>




                </div>
                <!-- /.form-box -->
            </div>
        </div><!-- /.box-body -->
    </div>



    @*<button type="submit" value="sumbit">SAVE</button>*@
}
