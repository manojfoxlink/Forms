@model ChecklistForm.Models.CircuitRecordViewModel
@{
    ViewBag.Title = "CircuitRecord";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@*<h2>CircuitRecord</h2>*@
@{
    Html.RenderPartial("_ErrorMessage");
}
@using (Html.BeginForm("CircuitRecord", "Master", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true)
    
    <div class="box box-solid box-warning">
        <div class="box-header">
            @*<h3 class="box-title">Create New ID</h3>*@
            <div class="box-tools pull-right">
                <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                    <i class="fa fa-minus"></i>
                </button>
            </div>
        </div><!-- /.box-header -->
        <div class="box-body">

            <div class="register-box">
                <div class="register-logo">
                    @*<a href="../Home/Index"><b>Create a NEW Project</b>User</a>*@
                    <a href="#"><b>CircuitBroad</b></a>
                </div>
                <div class="row">

                   
                </div>
                <div class="register-box-body">
                    @*<p class="login-box-msg">Register a new membership</p>*@

                    <form action=".." method="post">

                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(model => model.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "Select Project", new { @class = "form-control select2", @style = "width: 100%", required = "required" })<br />
                            @Html.ValidationMessageFor(model => model.ProjectId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>
                            <div class="form-group has-feedback">
                                @Html.TextBoxFor(x => x.Inspectionitem, new { placeholder = "Inspection item", @class = "form-control", autocomplete = "off",@required=true })
                                @Html.ValidationMessageFor(model => model.Inspectionitem, "", new { @class = "text-danger" })

                                <span class="glyphicon glyphicon-user form-control-feedback"></span>
                            </div>

                            <div class="form-group has-feedback">
                                @Html.TextBoxFor(x => x.ModelNumber, new { placeholder = "Model Number", @class = "form-control", autocomplete = "off",@required = true })
                                @Html.ValidationMessageFor(model => model.ModelNumber, "", new { @class = "text-danger" })

                                <span class="glyphicon glyphicon-user form-control-feedback"></span>
                            </div>

                            <div class="form-group has-feedback">
                                @Html.TextBoxFor(x => x.InspecSpecification, new { placeholder = "Inspection Specification", @class = "form-control", autocomplete = "off",@required = true })
                                @Html.ValidationMessageFor(model => model.InspecSpecification, "", new { @class = "text-danger" })

                                <span class="glyphicon glyphicon-user form-control-feedback"></span>
                            </div>

                            <div class="row">
                                <div class="col-xs-4">

                                </div>
                                <div class="col-xs-4">
                                    <button type="submit" class="btn btn-success btn-block btn-flat">Create</button>
                                </div>
                                @*<div class="col-xs-4">
                    <button type="submit" class="btn btn-success btn-block btn-flat">Search</button>
                </div>
                <div class="col-xs-4">
                    <button type="submit" class="btn btn-success btn-block btn-flat">Update</button>
                </div>*@
                                <!-- /.col -->
                                <div class="col-xs-4">

                                </div>
                                <!-- /.col -->
                            </div>
                            <div class="row">
                                <div class="col-xs-2">

                                </div>
                                <div class="col-xs-8">
                                    <h3 class="text-danger">@ViewBag.ResultMessage</h3>
                                </div>
                                <!-- /.col -->
                                <div class="col-xs-2">

                                </div>
                                <!-- /.col -->
                            </div>
</form>

                    


                </div>
                <!-- /.form-box -->
            </div>
        </div><!-- /.box-body -->
    </div>
 
}
