@model ChecklistForm.Models.CheckListNativeValidationModelView
@{
    ViewBag.Title = "CheckListNativeProduction";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    Html.RenderPartial("_ErrorMessage");
}
<style>
    .padding {
        padding: 10px;
    }
</style>
@using (Html.BeginForm("CheckListNativeProduction", "CheckList", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
{
    <div class="box box-solid box-default">
        <div class="box-header">

            <h3 class="box-title">Negative Validation</h3>
        </div><!-- /.box-header -->
        <div class="box-body">

            <div class="box padding">
                <div class="row" style="padding-top:15px">
                    <div class="col-lg-10 col-md-12 col-sm-12 col-xs-12">

                        <div class="form-group">
                            <div class="row">

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.LineId, new SelectList(Model.Lines, "LineId", "LineName", 0), "--select Line--", new { @class = "form-control",required="required" })


                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "--select Project--", new { @class = "form-control", onchange = "ddlModelNoByProject();", required = "required" })


                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.ModelId, new SelectList(Model.ModelNos, "ModelId", "Model", 0), "--Select Model--", new { @class = "form-control", onchange = "ddlGetPartNoByModel()", required = "required" })

                                    <span class="glyphicon glyphicon-user form-control-feedback"></span>
                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.PartId, new SelectList(Model.PartNos, "PartId", "Part", 0), "--Select Part--", new { @class = "form-control", required = "required" })

                                    <span class="glyphicon glyphicon-user form-control-feedback"></span>
                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.ProdLineLeader, new { placeholder = "Production LineLeader", @class = "form-control", autocomplete = "off", @required = true })
                                </div>

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.CheckedBy, new { placeholder = "CheckedBy", @class = "form-control", autocomplete = "off", @required = true })
                                </div>

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.ApprovedBy, new { placeholder = "ApprovedBy", @class = "form-control", autocomplete = "off", @required = true })
                                </div>
                                
                                
                                    <div class="col-lg-2 col-md-3 col-sm-1 col-xs-12">

                                        <button type="submit" class="btn btn-success" name="Command" value="Search" id="btnSearch">Search</button>
                                    </div>
                                </div>

                        </div>
                    </div>
                </div>
            </div>

            <div class="box padding">
                <div class="row">
                    <table class="table table-bordered table-hover" role="grid" aria-describedby="example3_info" id="QuastionTable">
                        <thead>
                            <tr>
                                <td style="color:red">
                                   <b>NOTATION:-</b>
                                <br />
                                <b>
                                    Good Sample indicates good. it must be OK.
                                </b>
                                <br />
                                <b>
                                    Good Sample indicates abnormal. it must be NG.
                                </b>
                                <br />
                                <b>
                                    Fail Sample indicates good. it must be NG.
                                </b>
                                <br />
                                <b>
                                    Fail Sample indicates abnormal. it must be OK.
                                </b>

                        </td>
                            </tr>
                            <tr role="row">
                                <th style="display:none">
                                    ValidId
                                </th>
                                <th>
                                    station
                                </th>
                                
                                <th>
                                    Inspection
                                </th>
                                <th>
                                    Frequency
                                </th>
                                <th>
                                    Periods
                                </th>
                                <th>
                                    Good Sample
                                </th>
                                <th>
                                    Fail Sample
                                </th>
                                <th>
                                    Action
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                               int row = 1;
                               int TotalCount = 0;

                               int row2 = 1;
                               int TCount = 0;

                               int row3 = 1;
                               int TCount2 = 0;
                            }

                            @foreach (System.Data.DataRow item in Model.dtChecklist.Rows)
                            {
                                <tr>
                                    @{
                                TotalCount = (Int32)@item["TotalCount"];
                                TCount = (Int32)@item["TCount"];
                                TCount2 = (Int32)@item["TCount2"];
                                    }

                                    
                                    <td style="display:none">
                                        @item["ValidId"].ToString()
                                    </td>

                                  
                                    @if (row > (Int32)item["TotalCount"])
                                    {
                                        row = 1;


                                    }
                                    @if (row2 > (Int32)item["TCount"])
                                    {
                                        row2 = 1;


                                    }
                                    @if (row3 > (Int32)item["TCount2"])
                                    {
                                        row3 = 1;


                                    }
                                  
                                    
                                    @if (row == 1)
                                   {
                                        <td rowspan="@TotalCount">
                                            @item["StationName"].ToString()
                                        </td>
                                    }
                                   
                                    @if (row2 == 1)
                                    {
                                        <td rowspan="@TCount">
                                            @item["Inspection"].ToString()
                                        </td>
                                    }
                                    @if (row3 == 1)
                                    {
                                        <td rowspan="@TCount2">

                                            @item["Frequency"].ToString()

                                        </td>
                                    }

                                    <td>
                                        @item["Periods"].ToString()
                                    </td>
                                    <td>
                                        <input type="text" class="form-control" name="GoodSample" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control" name="FailSample" />
                                    </td>
                                    @*<td>
                                        <input type="text" class="form-control" name="Result" />
                                    </td>*@
                                    <td>
                                        <button type="button" name="Command" id="btnSave" onclick="Save()" value="SUMBIT" class="btn btn-primary btn-flat">Save</button>
                                    </td>

                                    @if (row == TotalCount)
                                    {
                                        row = 1;
                                    }
                                    else
                                    {
                                        row += 1;
                                    }

                                    @if (row2 == TCount)
                                    {
                                        row2 = 1;
                                    }
                                    else
                                    {
                                        row2 += 1;
                                    }

                                    @if (row3 == TCount)
                                    {
                                        row3 = 1;
                                    }
                                    else
                                    {
                                        row3 += 1;
                                    }

                                </tr>



                            }


                        </tbody>
                        <tfoot>

                        </tfoot>

                    </table>

                </div>

                <div class="row padding">
                    <div class="col-xs-10 right">

                        <button type="button" name="Command" id="btnSave" onclick="Save()" value="SUMBIT" class="btn btn-primary btn-flat">Submit</button>


                    </div>

                </div>
            </div>
        </div>
    </div>
}

