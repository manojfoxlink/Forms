                    var GoodSample = $tds.eq(2).find('input').val();
                    var FailSample = $tds.eq(3).find('input').val();
                    //var Result = $tds.eq(4).find('input').val();

                    if (GoodSample != "") {
                        if (GoodSample == "") {
                            $tds.eq(2).find('input').val("");
                            $('#' + ValidId).css("border", '1px solid red');
                        } else {
                            $('#' + ValidId).css("border", '1px solid green');
                        }
                    }
                    else if (FailSample != "") {
                        if (FailSample == "") {
                            $tds.eq(3).find('input').val("");
                            $('#' + ValidId).css("border", '1px solid red');
                        } else {
                            $('#' + ValidId).css("border", '1px solid green');
