                //if ((GoodSample != "" && FailSample != "" && Result!="")) {
                //    CheckListResult[J] = {
                //        'ValidId': ValidId, 'GoodSample': GoodSample, 'FailSample': FailSample, 'Result': Result
                //    };
                //    J++;
                //}

                if ((GoodSample != "" && FailSample != "")) {
                    CheckListResult[J] = {
                        'ValidId': ValidId, 'GoodSample': GoodSample, 'FailSample': FailSample
                    };
                    J++;
                }
                i++;
            });
            var reqListObj = new Object();
            reqListObj.CheckListNativeValidations = CheckListResult;
            reqListObj.LineId = LineId;
            reqListObj.ProjectId = ProjectId;
            reqListObj.ProdLineLeader = ProdLineLeader;
            reqListObj.CheckedBy = CheckedBy;
            reqListObj.ApprovedBy = ApprovedBy;
            reqListObj.ModelId = ModelId;
            reqListObj.PartId = PartId;
            if (CheckListResult.length > 0) {
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/CheckList/SaveNativeProduction",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                        //   window.location.reload();
                        $("#btnSearch").click();
                    },
                    error: function () {
                        // alert('error');
                    }

                })
            }
            else {
                alert("Alteast one Part needed for Creating TO Request");
            }
        } else {
            alert("Please Select LineId");
        }
    }

</script>



