<script src="~/Scripts/jquery-ui-1.12.1.js"></script>
<link href="~/Content/jquery-ui-1.12.1.css" rel="stylesheet" />



<script>




    function Save() {
        //  var table = $("#QuastionTable");
        var CheckListResult = [];
        var fills = [];
        var i = 0;
        var J = 0;
        var k = 0;
        debugger;



        var table = $("table tbody");
        var formData = new FormData();
        //var LineId = $("#LineId").val();
        var ProjectId = $("#ProjectId").val();
        //var ProdLineLeader = $("#ProdLineLeader").val();
        var CheckedBy = $("#CheckedBy").val();
        var ApprovedBy = $("#ApprovedBy").val();

        var CustomerPin = $("#CustomerPin").val();
        var LotSize = $("#LotSize").val();
        var FinishedProductNo = $("#FinishedProductNo").val();
        var Rev = $("#Rev").val();
        var PackingListNo = $("#PackingListNo").val();
        var InspectResult = $("#InspectResult").val();
        debugger;
        if (ProjectId != 0 && CheckedBy != "" && ApprovedBy != "" && CustomerPin != "" && LotSize != "" && FinishedProductNo != "" && Rev != "" && PackingListNo != "") {

            table.find('tr').each(function (i) {
                var $tds = $(this).find('td'),
                    checkItemObservation = $tds.eq(4).find('input').val()

                if ((typeof checkItemObservation != "undefined")) {
                    var ContentId = $tds.eq(0).text().trim();

                    var Result = $tds.eq(4).find('input').val();

                    if (Result != "") {
                        $tds.eq(4).find('input').val("");
                    }

                    else {
                        $('#' + ContentId).css("border", '1px solid red');
                    }
                }
                else {
                    var ContentId = $tds.eq(0).text().trim();

                    var Result = $tds.eq(3).find('input').val();


                    if (Result != "") {
                        $tds.eq(3).find('input').val("");
                    }

                    else {
                        $('#' + ContentId).css("border", '1px solid red');
                    }

                }


                if (Result != "") {
                    CheckListResult[J] = {
                        'ContentId': ContentId, 'Result': Result
                    };
                    J++;
                }
                i++;
            });
            var reqListObj = new Object();
            reqListObj.CheckListoutGoingInspectionResults = CheckListResult;
            //reqListObj.LineId = LineId;
            reqListObj.ProjectId = ProjectId;
            //reqListObj.ProdLineLeader = ProdLineLeader;
            reqListObj.CheckedBy = CheckedBy;
            reqListObj.ApprovedBy = ApprovedBy;
            reqListObj.CustomerPin = CustomerPin;
            reqListObj.LotSize = LotSize;
            reqListObj.FinishedProductNo = FinishedProductNo;
            reqListObj.Rev = Rev;
            reqListObj.PackingListNo = PackingListNo;
            reqListObj.InspectResult = InspectResult;
            if (CheckListResult.length > 0) {
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/CheckList/SaveOutGoingInspection",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                        //   window.location.reload();
                        $("#btnSearch").click();
                    },
                    error: function () {
                        // alert('error');
                    }

                })
            }
            else {
                alert("Alteast one Part needed for Creating TO Request");
            }
        } else {
            alert("Please Select Customer P/N,LOTSize and Remaining Details");
        }
    }

</script>



