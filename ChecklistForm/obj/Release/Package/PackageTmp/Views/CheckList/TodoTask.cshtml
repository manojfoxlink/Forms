    $(function () {
        $('#selectAll').click(function () {
            debugger;
            if (this.checked) {
                $(".checkboxes").prop("checked", true);
            } else {
                $(".checkboxes").prop("checked", false);
            }
        });
    });

    function Approval() {
        debugger;

        //   showLoader();
        var Qurey = $("#Qurey").val();
        if (Qurey != "") {
            
            var isflag = false;
            var WorkFlowViewModel = [];

            var J = 0;
            var table = $("#example1 tbody");

            table.find('tr').each(function (i) {
                var $tds = $(this).find('td');
                var id = $tds.eq(0).text().trim();

                var isflageach = false;
                if ($('#' + id).is(':checked')) {
                    isflag = true;
                    isflageach = true;
                }
                if (isflageach) {

                    //$('#LeaveType' + id).css("border", '1px solid green');
                    $('#Reason' + id).css("border", '1px solid green');
                    var Pid = $tds.eq(0).text().trim();
                    var FACAId = $tds.eq(1).text().trim();
                    var TaskId = $tds.eq(2).text().trim();
                    var Applicant = $tds.eq(3).text().trim();
                    var ApprovedId = $tds.eq(4).text().trim();


                    WorkFlowViewModel[J] = {
                        'Pid': Pid, 'FACAId': FACAId, 'TaskId': TaskId, 'Applicant': Applicant,'ApprovedId':ApprovedId, 'Reason': Qurey
                    };
                    J++;

                }
            });


        }


        if (isflag) {

            var reqListObj = new Object();
            reqListObj.viewModelsResult = WorkFlowViewModel;



            if (WorkFlowViewModel.length > 0) {
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/CheckList/Approve",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                        window.location.reload();
                    },
                    error: function () {
                        // alert('error');
                    }

                })
            }
            else {
                alert("Alteast one checkbox needed to select");
            }

        } else {
            alert("Please select atleast one checkbox");
            return false;
        }

    }

