@model ChecklistForm.Models.WorkFlowViewModel
@{
    ViewBag.Title = "TodoTask";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    table {
        overflow-y: scroll; /* Always show vertical scrollbar */
        overflow-x: auto; /* Show horizontal scrollbar when needed */
    }
    .padding {
        padding: 10px;
    }

    #example1_wrapper {
        overflow: auto;
    }
</style>
<div class="box box-solid box-default">
    <div class="box-header">
        <h3 class="box-title">To do Task</h3>
        <div class="box-tools pull-right">
            <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                <i class="fa fa-minus"></i>
            </button>
        </div>
    </div>

    <div class="box-body ">
        @using (Html.BeginForm("TodoTask", "CheckList", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form", onsubmit = "showLoader(this);" }))
        {
            @Html.AntiForgeryToken()

            {
                Html.RenderPartial("_ErrorMessage");
            }

            <div class="box padding ">

                <table id="example1" class="table table-bordered table-hover" role="grid" aria-describedby="example1_info">
                    <thead>
                        <tr role="row">
                            <td style="display:none;">
                                Pid
                            </td>
                            <td style="display:none;">
                                FACAId
                            </td>
                            <td style="display:none;">
                                TaskId
                            </td>
                            <td style="display:none;">
                                Applicant
                            </td>
                            <td style="display:none;">
                                ApprovedId
                            </td>
                            <th>
                                <input type="checkbox" id="selectAll" name="selectAll" />
                            </th>

                            <th>
                                Project
                            </th>
                            <th>
                                Line
                            </th>
                            <th>
                                Batch
                            </th>
                            <th>
                                Zone
                            </th>
                            <th>
                                Station
                            </th>
                            <th>
                                Activity Description
                            </th>
                            <th>
                                Status
                            </th>
                            <th>
                                Remarks
                            </th>
                            <th>
                                Line Leader
                            </th>
                            <th>
                                Audit By
                            </th>
                            <th style="display:none;">
                                Description
                            </th>
                            <th>
                                Root Cause
                            </th>
                            <th>
                                Corrective Action
                            </th>
                            <th style="display:none;">
                                Preventive Action
                            </th>
                            <th>
                                Image
                            </th>
                        </tr>
                    </thead>
                    <tbody>

                        @foreach (System.Data.DataRow binRow in Model.WorkFlowList.Rows)
                        {
                            <tr>

                                <td style="display:none;">

                                    @binRow["Pid"].ToString()
                                </td>
                                <td style="display:none;">

                                    @binRow["FACAId"].ToString()
                                </td>
                                <td style="display:none;">

                                    @binRow["TaskId"].ToString()
                                </td>
                                <td style="display:none;">

                                    @binRow["Applicant"].ToString()
                                </td>
                                <td style="display:none;">

                                    @binRow["TaskApproveId"].ToString()
                                </td>
                                <td>
                                    <input type="checkbox" id="@binRow["Pid"].ToString()" class="checkboxes" name="chk" value="@binRow["FACAId"].ToString()" />
                                </td>

                                <td>

                                    @binRow["ProjectName"].ToString()
                                </td>

                                <td>
                                    @binRow["LineName"].ToString()
                                </td>

                                <td>
                                    @binRow["BatchName"].ToString()
                                </td>

                                <td>

                                    @binRow["ZoneName"].ToString()
                                </td>
                                <td>
                                    @binRow["Module"].ToString()
                                </td>

                                <td>
                                    @binRow["Points"].ToString()
                                </td>

                                <td>

                                    @binRow["Status"].ToString()

                                </td>
                                <td>
                                    @binRow["Namee"].ToString()
                                </td>

                                <td>
                                    @binRow["LineLeader"].ToString()

                                </td>
                                <td>
                                    @binRow["AuditedBy"].ToString()

                                </td>
                                <td style="display:none;">
                                    @binRow["Descrription"].ToString()

                                </td>
                                <td>
                                    @binRow["RootCause"].ToString()
                                </td>
                                <td>
                                    @binRow["CorrectiveAction"].ToString()
                                </td>
                                <td style="display:none;">
                                    @binRow["PreventiveAction"].ToString()
                                </td>
                                <td>
                                    @if (@binRow["Image"].ToString() != "")
                                    {



                                        <a href="@Url.Action("Download", "CheckList", new { Image = @binRow["Image"].ToString() })" target="_blank" title="List View" class="links">
                                            <img alt="List View" src="@Url.Content(@binRow["Image"].ToString())" width="150" height="150">
                                            @*<img alt="List View" src="@Url.Content(@item["Image"].ToString())" style="max-height:100%;max-width:100%;">*@
                                        </a>

                                    }
                                    else
                                    {
                                        <img src="../AdminStyle/dist/img/avatar5.png" style="max-height:30%;max-width:50%;" alt="User Image">
                                    }
                                </td>



                            </tr>


                        }
                    </tbody>
                    <tfoot>

                    </tfoot>

                </table>
            </div>
            <div class="row padding">

                @*<div class="col-lg-3 col-md-2 col-sm-2 col-xs-0">
                        Required:@Html.RadioButtonFor(m => m.CostEstimation, true,"")
                        Not Required: @Html.RadioButtonFor(m => m.CostEstimation, false,"false")
                    </div>

                    <div class="col-lg-3 col-md-2 col-sm-2 col-xs-4">
                        <input type="file" name="file"/>
                    </div>*@


                <div class="col-lg-offset-3 col-md-3 col-sm-2 col-xs-0">


                    <label>Query</label>
                    <textarea class="form-control" rows="3" placeholder="Enter ..." spellcheck="false" id="Qurey"></textarea>

                </div>
                <div class="col-lg-2 col-md-2 col-sm-2 col-xs-4">

                </div>
            </div>

            <div class="row padding">

                <div class="col-lg-2 col-md-2 col-sm-2 col-xs-0">
                </div>

                <div class="col-lg-2 col-md-2 col-sm-2 col-xs-4">

                </div>
                <div class="col-lg-4 col-md-2 col-sm-2 col-xs-0">
                    @*<button type="button" id="Approve" onclick="Approval()" class="btn btn-primary btn-outline-primary">Approve</button>
                        <button type="button" id="Reject" onclick="Rejected()" class="btn btn-danger btn-outline-danger">Reject</button>*@

                    <button type="button" id="Approve" onclick="Approval()" class="btn btn-primary">Approve</button>
                    <button type="button" id="Reject" onclick="Rejected()" class="btn btn-danger">Reject</button>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4 col-xs-1">

                </div>

            </div>

        }
    </div>
</div>





