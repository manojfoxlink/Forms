<script src="~/Scripts/jquery-ui-1.12.1.js"></script>
<link href="~/Content/jquery-ui-1.12.1.css" rel="stylesheet" />



<script>




    function Save() {
        //  var table = $("#QuastionTable");
        var CheckListResult = [];
        var fills = [];
        var i = 0;
        var J = 0;
        var k = 0;
        debugger;



        var table = $("table tbody");
        var formData = new FormData();
        var LineId = $("#LineId").val();
        var ProjectId = $("#ProjectId").val();
        var ProdLineLeader = $("#ProdLineLeader").val();
        var CheckedBy = $("#CheckedBy").val();
        var ApprovedBy = $("#ApprovedBy").val();
        var ModelId = $("#ModelId").val();
        var PartId = $("#PartId").val();

        if (LineId != 0 && ProjectId != 0 && ProdLineLeader != "" && CheckedBy != "" && ApprovedBy != "" && ModelId != 0 && PartId != 0) {

            table.find('tr').each(function (i) {
                var $tds = $(this).find('td'),
                    checkItemObservation = $tds.eq(5).find('input').val()
                debugger;

                if ((typeof checkItemObservation != "undefined")) {
                    var CheckId = $tds.eq(0).text().trim();
                  
                    var Status = $tds.eq(5).find('input').val();
                    var Image = $tds.eq(8).find('input').val();

                    if (Status != "") {
                        if (Status == "") {
                            $tds.eq(5).find('input').val("");
                            $('#' + CheckId).css("border", '1px solid red');
                        } else {
                            $('#' + CheckId).css("border", '1px solid green');
                        }
                    }
                    

                    


                }
                else {
                    var CheckId = $tds.eq(0).text().trim();

                    var Status = $tds.eq(3).find('input').val();
                    var Image = $tds.eq(6).find('input').val();

                    if (Status != "") {
                        if (Status == "") {
                            $tds.eq(3).find('input').val("");
                            $('#' + CheckId).css("border", '1px solid red');
                        } else {
                            $('#' + CheckId).css("border", '1px solid green');
                        }
                    }
                    
                }

                if ((Status != "")) {
                    CheckListResult[J] = {
                        'CheckId': CheckId, 'Status': Status,'Image':Image
                    };
                    J++;
                }
                i++;
            });
            var reqListObj = new Object();
            reqListObj.CheckListAuditChecksResults = CheckListResult;
            reqListObj.LineId = LineId;
            reqListObj.ProjectId = ProjectId;
            reqListObj.ProdLineLeader = ProdLineLeader;
            reqListObj.CheckedBy = CheckedBy;
            reqListObj.ApprovedBy = ApprovedBy;
            reqListObj.ModelId = ModelId;
            reqListObj.PartId = PartId;
            if (CheckListResult.length > 0) {
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/CheckList/SaveAuditCheckPoints",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                        //   window.location.reload();
                        $("#btnSearch").click();
                    },
                    error: function () {
                        // alert('error');
                    }

                })
            }
            else {
                alert("Alteast one Part needed for Creating TO Request");
            }
        } else {
            alert("Please Select LineId");
        }
    }

    //$(document).ready(function () {
    //    debugger;

    //        var LineId = $("#LineId").val();

    //        if (LineId != 0)
    //        $("#btnSearch").click();

    //});

    function uploadFile(id) {
        debugger;
        if (window.FormData !== undefined) {
            var fileUpload = $("#FileUpload1-"+id).get(0);
            var files = fileUpload.files;
            if (files.length > 0) {
                // Create FormData object
                var fileData = new FormData();

                // Looping over all files and add it to FormData object
                for (var i = 0; i < files.length; i++) {
                    fileData.append(files[i].name, files[i]);
                }

                $.ajax({
                    url: '/CheckList/UploadDocument',
                    type: "POST",
                    contentType: false, // Not to set any content header
                    processData: false, // Not to process data
                    data: fileData,
                    success: function (result) {
                        //var id = $('#hdnDocId').val();
                        $('#Path-' + id).val(result);
                        $('#lblUploadStatus-'+id).show();
                        $('#btnUpload-' + id).css("display", "none");
                        $('#lblUploadStatu-' + id).text("Succesfully Uploaded");
                        $("#FileUpload1-"+id).val(null);
                        //$('#hdnDocId').val(" ");
                    },
                    error: function (err) {
                        alert(err.statusText);
                    }
                });
            } else {
                alert("Choose the File");

            }
        } else {
            alert("FormData is not supported.");
        }

    }

</script>
