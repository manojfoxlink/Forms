    function Approval() {
        debugger;

        //   showLoader();
        // var Qurey = $("#Qurey").val();

        var isflag = false;
        var WorkFlowViewModel = [];

        var J = 0;
        var table = $("#example1 tbody");

        table.find('tr').each(function (i) {
            var $tds = $(this).find('td');
            var id = $tds.eq(0).text().trim();

            var isflageach = false;
            if ($('#' + id).is(':checked')) {
                isflag = true;
                isflageach = true;
            }
            debugger;
            if (isflageach) {

                //$('#LeaveType' + id).css("border", '1px solid green');
                $('#Reason' + id).css("border", '1px solid green');
                var Pid = $tds.eq(0).text().trim();
                var ResultId = $tds.eq(1).text().trim();
                //var MenuId = $tds.eq(2).text().trim();
                var LaserId = $tds.eq(2).text().trim();
                var TaskId = $tds.eq(3).text().trim();
                var ApproveId = $tds.eq(4).text().trim();
                var Remark = $tds.eq(27).find('input').val();
                var Query = $tds.eq(26).find('input').val();

                WorkFlowViewModel[J] = {
                    'Pid': Pid, 'ResultId': ResultId, 'LaserId': LaserId, 'TaskId': TaskId, 'ApproveId': ApproveId, 'Reason': Query, 'Remark': Remark
                };
                J++;
            }
        });

        if (isflag) {
            var reqListObj = new Object();
            reqListObj.viewModelsResult = WorkFlowViewModel;

            if (WorkFlowViewModel.length > 0) {
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/CheckList/A191LaserApprove",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                        window.location.reload();
                    },
                    error: function () {
                        // alert('error');
                    }
                })
            }
            else {
                alert("At least one checkbox needs to be selected");
            }
        } else {
            alert("Please select at least one checkbox");
            return false;
        }
    }




