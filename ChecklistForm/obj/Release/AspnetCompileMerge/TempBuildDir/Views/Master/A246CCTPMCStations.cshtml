@model ChecklistForm.Models.A246CCTPMCStationsViewModel

@{
    ViewBag.Title = "A246CCTPMCStations";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    Html.RenderPartial("_ErrorMessage");
}

@using (Html.BeginForm("A246CCTPMCStations", "Master", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true)


    <div class="box box-solid box-warning">
        <div class="box-header">
            @*<h3 class="box-title">Create New ID</h3*@>
            <div class="box-tools pull-right">
                <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                    <i class="fa fa-minus"></i>
                </button>
            </div>
        </div><!-- /.box-header -->
        <div class="box-body">

            <div class="register-box">
                <div class="register-logo">
                    <a href="#"><b>A246C CTP Stations For Line-1</b></a>
                </div>

                <div class="register-box-body">
                    @*<p class="login-box-msg">Register a new membership</p>*@

                    <form action=".." method="post">
                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(x => x.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "--select Project--", new { @class = "form-control", onchange = "ddlA246CMachinesByProject();", required = "true" })
                            @Html.ValidationMessageFor(model => model.ProjectId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>
                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(x => x.MachineId, new SelectList(Model.Machines, "MachineId", "Machine", 0), "--select Machine--", new { @class = "form-control", required = "true" })
                            @Html.ValidationMessageFor(model => model.MachineId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>
                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.StationNo, new { placeholder = "Station No", @class = "form-control", autocomplete = "off", @required = "true" })
                            @Html.ValidationMessageFor(model => model.StationNo, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.Station, new { placeholder = "Station Name", @class = "form-control", autocomplete = "off", @required = "true" })
                            @Html.ValidationMessageFor(model => model.Station, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.EquipmentModel, new { placeholder = "Equipment Model", @class = "form-control", autocomplete = "off", @required = "true" })
                            @Html.ValidationMessageFor(model => model.EquipmentModel, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        @*<div class="form-group has-feedback">
                                @Html.TextBoxFor(x => x.UpperLimit, new { placeholder = "Upper Limit", @class = "form-control", autocomplete = "off", @required = "true" })
                                @Html.ValidationMessageFor(model => model.UpperLimit, "", new { @class = "text-danger" })
                                <span class="glyphicon glyphicon-user form-control-feedback"></span>
                            </div>*@

                        <div class="row">
                            <div class="col-xs-4">

                            </div>
                            <div class="col-xs-4">
                                <button type="submit" class="btn btn-success btn-block btn-flat">Submit</button>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-4">

                            </div>
                            <!-- /.col -->
                        </div>
                        <div class="row">
                            <div class="col-xs-2">

                            </div>
                            <div class="col-xs-8">
                                <h3 class="text-danger">@ViewBag.ResultMessage</h3>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-2">

                            </div>
                            <!-- /.col -->
                        </div>
                    </form>




                </div>
                <!-- /.form-box -->
            </div>
        </div><!-- /.box-body -->
    </div>





}