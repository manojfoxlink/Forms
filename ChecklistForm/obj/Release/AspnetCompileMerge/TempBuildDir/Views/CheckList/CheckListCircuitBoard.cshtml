@model ChecklistForm.Models.CheckListCircuitBoardResultModelView
@{
    ViewBag.Title = "CheckListCircuitBoard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    Html.RenderPartial("_ErrorMessage");
}
<style>
    .padding {
        padding: 10px;
    }

    .table-container {
        max-height: 500px; /* Adjust as needed */
        overflow-y: auto; /* Enables vertical scrolling */
        border: 1px solid #ccc;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
    }

        .table thead th {
            position: sticky;
            top: 0;
            background-color: #f9f9f9; /* Optional: Background color */
            z-index: 10; /* Keeps the header on top */
            border-bottom: 1px solid #ddd;
            padding: 10px;
            text-align: left;
        }

        .table tbody td {
            padding: 10px;
            border-bottom: 1px solid #ddd;
        }

    .custom-dropdown {
        width: 68px;
        height: 34px;
    }
</style>
@using (Html.BeginForm("CheckListCircuitBoard", "CheckList", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
{
    <div class="box box-solid box-default">
        <div class="box-header">

            <h3 class="box-title">A191/A191m Process Tour</h3>
        </div><!-- /.box-header -->
        <div class="box-body">

            <div class="box padding">
                <div class="row" style="padding-top:15px">
                    <div class="col-lg-10 col-md-12 col-sm-12 col-xs-12">

                        <div class="form-group">
                            <div class="row">

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.LineId, new SelectList(Model.Lines, "LineId", "LineName", 0), "--select Line--", new { @class = "form-control", required = "required" })


                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "--select Project--", new { @class = "form-control", onchange = "ddlModelNoByProject();", required = "required" })


                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.ModelId, new SelectList(Model.ModelNos, "ModelId", "Model", 0), "--Select Model--", new { @class = "form-control", onchange = "ddlGetPartNoByModel()", required = "required" })

                                    <span class="glyphicon glyphicon-user form-control-feedback"></span>
                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.PartId, new SelectList(Model.PartNos, "PartId", "Part", 0), "--Select Part--", new { @class = "form-control", required = "required" })

                                    <span class="glyphicon glyphicon-user form-control-feedback"></span>
                                </div>

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.ProcessTourId, new SelectList(Model.ProcessTourss, "ProcessTourId", "ProcessTours", 0), "--select Module--", new { @class = "form-control",  required = "required" })


                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.ProdLineLeader, new { placeholder = "Production LineLeader", @class = "form-control", autocomplete = "off", @required = true })
                                </div>

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.CheckedBy, new { placeholder = "CheckedBy", @class = "form-control", autocomplete = "off", @required = true })
                                </div>

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.ApprovedBy, new { placeholder = "ApprovedBy", @class = "form-control", autocomplete = "off", @required = true })
                                </div>

                                <div class="col-lg-2 col-md-3 col-sm-1 col-xs-12">

                                    <button type="submit" class="btn btn-success" name="Command" value="Search" id="btnSearch">Search</button>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <div class="box padding ">
                <div class="row table-container">
                    <table class="table table-bordered table-hover table-responsive" role="grid" aria-describedby="example3_info" id="QuastionTable">
                        <thead>
                            <tr role="row table-container">
                                <th style="display:none">
                                    SpecId
                                </th>
                                <th>
                                    station
                                </th>

                                <th>
                                    Inspection Item
                                </th>
                                <th>
                                    Lower Limit
                                </th>
                                <th>
                                    Upper Limit
                                </th>
                                <th>
                                    Inspection Specification
                                </th>
                                <th>
                                    Frequency
                                </th>
                                <th>
                                    periods
                                </th>
                                <th>
                                    Value1
                                </th>
                                <th>
                                    Value2
                                </th>
                                <th>
                                    Value3
                                </th>
                                <th>
                                    Value4
                                </th>
                                <th>
                                    Value5
                                </th>
                                <th>
                                    Action
                                </th>
                                @*<th>
                                        Result
                                    </th>*@
                            </tr>
                        </thead>
                        <tbody>
                            @{
    int row = 1;
    int TotalCount = 0;
                            }

                            @foreach (System.Data.DataRow item in Model.dtChecklist.Rows)
                            {
                                <tr>
                                    @{
                                TotalCount = (Int32)@item["TotalCount"];

                                    }


                                    <td style="display:none">
                                        @item["SpecId"].ToString()
                                    </td>


                                    @if (row > (Int32)item["TotalCount"])
                                    {
                                        row = 1;


                                    }


                                    @if (row == 1)
                                    {
                                        <td rowspan="@TotalCount">
                                            @item["StationName"].ToString()
                                        </td>

                                        <td rowspan="@TotalCount">
                                            @item["InspectionItem"].ToString()
                                        </td>

                                        <td rowspan="@TotalCount">
                                            @item["LowerLimit"].ToString()
                                        </td>

                                        <td rowspan="@TotalCount">
                                            @item["UpperLimit"].ToString()
                                        </td>
                                        <td rowspan="@TotalCount">
                                            @item["InspectionSpecification"].ToString()
                                        </td>

                                        <td rowspan="@TotalCount">
                                            @item["Freq"].ToString()
                                        </td>
                                    }

                                    <td>
                                        @item["Period"].ToString()
                                    </td>
                                    <td>
                                        <input type="text" class="form-control custom-dropdown" name="Value1" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control custom-dropdown" name="Value2" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control custom-dropdown" name="Value3" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control custom-dropdown" name="Value4" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control custom-dropdown" name="Value5" />
                                    </td>
                                    <td>
                                        <button type="button" name="Command" id="btnSave" onclick="Save()" value="SUMBIT" class="btn btn-primary btn-flat">Save</button>
                                    </td>

                                    @if (row == TotalCount)
                                    {
                                        row = 1;
                                    }
                                    else
                                    {
                                        row += 1;
                                    }

                                </tr>



                            }


                        </tbody>
                        <tfoot>

                        </tfoot>

                    </table>

                </div>

                <div class="row padding">
                    <div class="col-xs-10 right">

                        <button type="button" name="Command" id="btnSave" onclick="Save()" value="SUMBIT" class="btn btn-primary btn-flat">Submit</button>


                    </div>

                </div>
            </div>
        </div>
    </div>
}

