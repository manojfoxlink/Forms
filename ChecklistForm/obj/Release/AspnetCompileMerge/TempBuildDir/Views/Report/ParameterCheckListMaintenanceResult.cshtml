                            </th>
                            <th>
                                Standard Condition
                            </th>
                            <th>
                                Result
                            </th>
                            <th>
                                Remarks
                            </th>

                        </tr>
                    </thead>
                    <tbody>

                        @foreach (System.Data.DataRow item in Model.dtReports.Rows)
                        {
                            if (@item["PartsId"].ToString() == "1")
                            {
                                <tr>
                                    <td colspan="11" class="bg-gray">@item["Createdtime"].ToString()</td>
                                </tr>
                            }

                            <tr>


                                <td style="display:none">
                                    @item["PartsId"].ToString()
                                </td>
                                <td>
                                    @item["Sno"].ToString()
