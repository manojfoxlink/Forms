@using System.Data
@model ChecklistForm.Models.CheckListMaintenanceModelView

@{
    ViewBag.Title = "ParameterCheckListMaintenanceResult";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .padding {
        padding: 10px;
    }

    #example1_wrapper {
        overflow: auto;
    }
</style>

@using (Html.BeginForm("ParameterCheckListMaintenanceResult", "Report"))
{
    @Html.AntiForgeryToken()
    <div class="box box-solid box-default">
        <div class="box-header">
            <h3 class="box-title">Maintenance CheckList Report</h3>
        </div>

        @{
    Html.RenderPartial("_ErrorMessage");
        }
        <div class="box-body">
            <div class="box padding">
                <div class="row" style="padding-top:15px">
                    <div class="col-lg-10 col-md-12 col-sm-12 col-xs-12">

                        <div class="form-group">
                            <div class="row">

                                <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                    @Html.DropDownListFor(model => model.LineId, new SelectList(Model.Lines, "LineId", "LineName", 0), "--select Line--", new { @class = "form-control"})


                                </div>

                                <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                    @Html.DropDownListFor(model => model.ShiftId, new SelectList(Model.Shifts, "shiftId", "ShiftName", 0), "--select Shift--", new { @class = "form-control" })
                                </div>

                                <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                    @Html.DropDownListFor(model => model.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "--select Project--", new { @class = "form-control", onchange = "ddlProjectsChanged5()" })
                                </div>

                                <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                    @Html.DropDownListFor(model => model.MachineId, new SelectList(Model.Machines, "MachineId", "MachineName", 0), "--select Machine--", new { @class = "form-control"})


                                </div>
                              
                                <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                    @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", @Id = "datepicker"})


                                </div>

                                <div class="col-lg-3 col-md-3 col-sm-3 col-xs-12">
                                    @Html.TextBoxFor(model => model.ToDate, new { @class = "form-control", @Id = "datepicker1"})


                                </div>
                                
                            </div>
                            <div class="row">
                                <div class="col-lg-2 col-md-3 col-sm-1 col-xs-12">

                                    <button type="submit" class="btn btn-success" name="Command" value="Search" id="btnSearch">Search</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <div class="row padding">
                @*<table class="table table-bordered table-hover bg-light-blue-gradient" role="grid" aria-describedby="example3_info" id="QuastionTable">
                    <thead>
                        <tr role="row" class="bg-light-blue-gradient">
