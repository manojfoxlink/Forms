                </table>*@



       @if (Model.dtReports.Rows.Count > 0)
        {
    <table id="example1" class="table table-bordered table-hover" role="grid" aria-describedby="example3_info">
        <thead>
            <tr >
                @foreach (DataColumn col in Model.dtReports.Columns)
                {
                    <th>@col.ColumnName</th>
                }

            </tr>
        </thead>
        <tbody>
            @foreach (DataRow row in Model.dtReports.Rows)
            {

                <tr>
                    @foreach (System.Data.DataColumn col in Model.dtReports.Columns)
                    {
                        <td>@row[col.ColumnName]</td>
                    }
                </tr>
            }
        </tbody>
    </table>
}








            </div>
            @if (Model.dtReports.Rows.Count > 0)
            {
                <div class="row padding">

                    <div class="col-lg-2 col-md-2 col-sm-2 col-xs-0">
                    </div>
                    <div class="col-lg-2 col-md-2 col-sm-2 col-xs-3">
                        <label>Export Format File :</label>
                    </div>
                    <div class="col-lg-2 col-md-2 col-sm-2 col-xs-4">
                       @Html.DropDownListFor(model => model.ExportType, new SelectList(Model.ExportTypes, Model.ExportType), new { @class = "form-control select2 select2-hidden-accessible", target = "_blank", @style = "width: 100%;" })
                    </div>
                    <div class="col-lg-2 col-md-2 col-sm-2 col-xs-4">
                        <button type="submit" name="Command" id="btnExport" value="Export" class="btn btn-primary btn-flat">Export File</button>
                    </div>
                    <div class="col-lg-4 col-md-4 col-sm-4 col-xs-1">

                    </div>

                </div>
            }

        </div>
    </div>
}
