                                    @item["PartOfInspection"].ToString()
                                </td>
                                <td>
                                    @item["Freq"].ToString()
                                </td>
                                <td>
                                    @item["StandardCondition"].ToString()
                                </td>
                                <td>
                                    @item["Result"].ToString()
                                </td>
