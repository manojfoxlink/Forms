@model ChecklistForm.Models.RptParameterA246CLaserEngraving

@{
    ViewBag.Title = "ParameterA246CLaserEngravingCheckList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .padding {
        padding: 10px;
    }

    #example1_wrapper {
        overflow: auto;
    }

    .table-container {
        max-height: 500px; /* Adjust as needed */
        overflow-y: auto; /* Enables vertical scrolling */
        border: 1px solid #ccc;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
    }

        .table thead th {
            position: sticky;
            top: 0;
            background-color: #f9f9f9; /* Optional: Background color */
            z-index: 10; /* Keeps the header on top */
            border-bottom: 1px solid #ddd;
            padding: 10px;
            text-align: left;
        }

        .table tbody td {
            padding: 10px;
            border-bottom: 1px solid #ddd;
        }


    #datepicker {
        position: relative;
        top: 100%;
        left: 0;
        background-color: #fff;
        border: 1px solid #ccc;
        padding: 5px;
        z-index: 1000;
    }
</style>

@using (Html.BeginForm("ParameterA246CLaserEngravingCheckList", "Report"))
{
    @Html.AntiForgeryToken()
    <div class="box box-solid box-default">
        <div class="box-header">
            <h3 class="box-title">A246C Laser Engraving</h3>
        </div>

        @*@{
            Html.RenderPartial("_ErrorMessage");
                }*@
        <div class="box-body">
            <div class="box padding">
                <div class="row" style="padding-top:15px">
                    <div class="col-lg-10 col-md-12 col-sm-12 col-xs-12">

                        <div class="form-group">
                            <div class="row">

                                <div class="col-lg-4 col-md-3 col-sm-3 col-xs-12">
                                    @Html.DropDownListFor(model => model.LineId, new SelectList(Model.Lines, "LineId", "LineName", 0), "--select Line--", new { @class = "form-control", required = "required" })


                                </div>

                                <div class="col-lg-4 col-md-3 col-sm-3 col-xs-12">
                                    @Html.DropDownListFor(model => model.ShiftId, new SelectList(Model.Shifts, "shiftId", "ShiftName", 0), "--select Shift--", new { @class = "form-control", required = "required" })


                                </div>

                                <div class="col-lg-4 col-md-3 col-sm-3 col-xs-12">
                                    @Html.TextBoxFor(model => model.FromDate, new { @class = "form-control", @Id = "datepicker", @required = "true" })


                                </div>

                                <div class="col-lg-4 col-md-3 col-sm-3 col-xs-12">
                                    @Html.DropDownListFor(model => model.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "--select Project--", new { @class = "form-control", required = "required" })


                                </div>



                                <div class="col-lg-2 col-md-3 col-sm-1 col-xs-12">

                                    <button type="submit" class="btn btn-success" name="Command" value="Search" id="btnSearch">Search</button>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <div class="box padding">
                <div class="row table-container">
                    <table class="table table-bordered table-hover" role="grid" aria-describedby="example3_info" id="QuastionTable">
                        <thead>
                            <tr role="row">

                                <th>
                                    Locations
                                </th>

                                <th>
                                    Specification
                                </th>
                                <th>
                                    Min
                                </th>
                                <th>
                                    Max
                                </th>

                                <th>
                                    Value1
                                </th>
                                <th>
                                    SerialNumber1
                                </th>
                                <th>
                                    Value2
                                </th>
                                <th>
                                    SerialNumber2
                                </th>

                                <th>
                                    Value3
                                </th>
                                <th>
                                    SerialNumber3
                                </th>

                                <th>
                                    Value4
                                </th>
                                <th>
                                    SerialNumber4
                                </th>

                                <th>
                                    Value5
                                </th>
                                <th>
                                    SerialNumber5
                                </th>
                                <th>
                                    InspectionResults
                                </th>

                                @*<th>
                                        InspectionResults
                                    </th>*@
                                @*<th>
                                        CablesSerialNumber
                                    </th>*@

                            </tr>
                        </thead>
                        <tbody>
                            @*@{
                                int laserTotal = 1;
                                                    }*@

                            @foreach (System.Data.DataRow item in Model.dtReports.Rows)
                            {

                                @*if (@item["LaserId"].ToString() == "1" || @item["LaserId"].ToString() == "11")
                                    {
                                        <tr>
                                            <td colspan="11" class="bg-gray">@item["CreatedDatetime"].ToString()</td>
                                        </tr>
                                    }*@

                                <tr>
                                    <td>
                                        @item["Locations"].ToString()
                                    </td>
                                    <td>
                                        @item["Specification"].ToString()
                                    </td>
                                    <td>
                                        @item["Min"].ToString()
                                    </td>
                                    <td>
                                        @item["Max"].ToString()
                                    </td>

                                    <td>
                                        @item["Value1"].ToString()
                                    </td>
                                    <td>
                                        @item["SerialNumber1"].ToString()
                                    </td>
                                    <td>
                                        @item["Value2"].ToString()
                                    </td>
                                    <td>
                                        @item["SerialNumber2"].ToString()
                                    </td>
                                    <td>
                                        @item["Value3"].ToString()
                                    </td>
                                    <td>
                                        @item["SerialNumber3"].ToString()
                                    </td>
                                    <td>
                                        @item["Value4"].ToString()
                                    </td>
                                    <td>
                                        @item["SerialNumber4"].ToString()
                                    </td>
                                    <td>
                                        @item["Value5"].ToString()
                                    </td>
                                    <td>
                                        @item["SerialNumber5"].ToString()
                                    </td>
                                    <td style="color: @item["Color"];">
                                        @item["Result"].ToString()
                                    </td>
                                    @*<td>
                                            @item["CablesSerialNumber"].ToString()
                                        </td>*@

                                </tr>



                            }


                        </tbody>
                        <tfoot>

                        </tfoot>

                    </table>






                </div>
            </div>

            @if (Model.dtReports.Rows.Count > 0)
            {
                <div class="row padding">

                    <div class="col-lg-2 col-md-2 col-sm-2 col-xs-0">
                    </div>
                    <div class="col-lg-2 col-md-2 col-sm-2 col-xs-3">
                        <label>Export Format File :</label>
                    </div>
                    <div class="col-lg-2 col-md-2 col-sm-2 col-xs-4">
                        @Html.DropDownListFor(model => model.ExportTypes, new SelectList(Model.ExportTypes, Model.ExportType), new { @class = "form-control select2 select2-hidden-accessible", target = "_blank", @style = "width: 100%;" })
                    </div>
                    <div class="col-lg-2 col-md-2 col-sm-2 col-xs-4">
                        <button type="submit" name="Command" id="btnExport" value="Export" class="btn btn-primary btn-flat">Export File</button>
                    </div>
                    <div class="col-lg-4 col-md-4 col-sm-4 col-xs-1">

                    </div>

                </div>
            }

        </div>
    </div>
}

<script src="~/Scripts/jquery-ui-1.12.1.js"></script>
<link href="~/Content/jquery-ui-1.12.1.css" rel="stylesheet" />
