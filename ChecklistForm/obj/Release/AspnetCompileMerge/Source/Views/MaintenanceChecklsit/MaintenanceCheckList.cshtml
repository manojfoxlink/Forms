@model ChecklistForm.Models.MaintenanceCheckListModelView
@{
    ViewBag.Title = "MaintenanceCheckList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    Html.RenderPartial("_ErrorMessage");
}
<style>
    .padding {
        padding: 10px;
