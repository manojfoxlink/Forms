    </style >
@using (Html.BeginForm("MaintenanceCheckList", "MaintenanceChecklsit", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
{
    <div class="box box-solid box-default">
        <div class="box-header">

            <h3 class="box-title"> MAINATENANCE CHECKSHEET</h3>
        </div><!-- /.box-header -->
        <div class="box-body">

            <div class="box padding">
                <div class="row" style="padding-top:15px">
                    <div class="col-lg-10 col-md-12 col-sm-12 col-xs-12">

                        <div class="form-group">
                            <div class="row">

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.LineId, new SelectList(Model.Lines, "LineId", "LineName", 0), "--select Line--", new { @class = "form-control", required = "required"})
                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "--select Project--", new { @class = "form-control", onchange = "ddlProjectsChanged3()", required = "required" })
                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.MachineId, new SelectList(Model.Machines, "MachineId", "MachineName", 0), "--select Machine--", new { @class = "form-control", required = "required" })
                                </div>
                                @*<div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.FreqId, new SelectList(Model.Frequencies, "FreqId", "Freq", 0), "--select Frequency--", new { @class = "form-control", required = "required" })
                                </div>*@
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.DRILeader, new { placeholder = "Maintenance DRI ", @class = "form-control", autocomplete = "off", @required = true })
                                </div>

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.LineLeader, new { placeholder = "LineLeader", @class = "form-control", autocomplete = "off", @required = true })
                                </div>


                                <div class="col-lg-2 col-md-3 col-sm-1 col-xs-12">

                                    <button type="submit" class="btn btn-success" name="Command" value="Search" id="btnSearch">Search</button>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <div class="box padding">
                <div class="row">
                    <table class="table table-bordered table-hover" role="grid" aria-describedby="example3_info" id="QuastionTable">
                        <thead>
                            <tr role="row">
                                @*<th>
                                    Machine
                                </th>*@
                                @*<th>
                                    Activity
                                </th>*@
                                <th style="display:none">
                                    PartsId
                                </th>
                                <th>
                                    S.No
                                </th>
                                <th>
                                   Part Of Inspection
                                </th>
                                <th>
                                    Freq
                                </th>
                                <th>
                                    Standard Condition
                                </th>
                                <th>
                                    Result
                                </th>
                                <th>
                                    Remarks
                                </th>
                                @*<th>
                                        Severity
                                    </th>*@

                                @*<th>

                                    </th>*@

                            </tr>
                        </thead>
                        <tbody>
                            @{
    //int row = 1;
    //int TotalCount = 0;

    //int row2 = 1;
    //int TCount = 0;
                            }
                            @foreach (System.Data.DataRow item in Model.dtChecklist.Rows)
                            {
                                <tr>
                                    
                                    
                                    @*@{
                                TotalCount = (Int32)@item["TotalCount"];
                                    }

                                    @if (row > (Int32)item["TotalCount"])
                                    {
                                        row = 1;


                                    }
                                    @if (row == 1)
                                    {


                                        <td rowspan="@TotalCount">

                                            @item["Activity"].ToString()



                                        </td>
                                    }*@
                                    <td style="display:none">
                                        @item["PartsId"].ToString()
                                    </td>
                                    <td>
                                        @item["Sno"].ToString()
                                    </td>
                                    <td>
                                        @item["PartOfInspection"].ToString()
                                    </td>
                                    <td>
                                        @item["Freq"].ToString()
                                    </td>
                                    <td>
                                        @item["StandardCondition"].ToString()
                                    </td>
                                    <td>
                                        <input type="checkbox"  name="Result" id="@item["PartsId"].ToString()" />
                                       
                                    </td>
                                    <td>
                                        <input type="text" class="form-control"  name="Remarks" id="@item["PartsId"].ToString()" />
                                    </td>
                                    <td>
                                        <button type="button" name="Command" id="btnSave" onclick="Save()" value="SUMBIT" class="btn btn-primary btn-flat">Save</button>
                                    </td>

                                    @*@if (row == TotalCount)
                                    {
                                        row = 1;
                                    }
                                    else
                                    {
                                        row += 1;
                                    }*@

                                   
                                </tr>



                            }


                        </tbody>
                        <tfoot>

                        </tfoot>

                    </table>

                </div>

                <div class="row padding">
                    <div class="col-xs-10 right">

                        <button type="button" name="Command" id="btnSave" onclick="Save()" value="SUMBIT" class="btn btn-primary btn-flat">Submit</button>


                    </div>

                </div>
            </div>
        </div>
    </div>
}

