<script src="~/Scripts/jquery-ui-1.12.1.js"></script>
<link href="~/Content/jquery-ui-1.12.1.css" rel="stylesheet" />




<script>


    
    
    function Save() {
        
        var CheckListResult = [];
        var fills = [];
        var i = 0;
        var J = 0;
        var k = 0;
        

        debugger;

        var table = $("table tbody");
        var formData = new FormData();
        var LineId = $("#LineId").val();
        var DRILeader = $("#DRILeader").val();
        var LineLeader = $("#LineLeader").val();
        var Result = false;
        if (LineId != 0 && DRILeader != "" && LineLeader!= "") {
            
            table.find('tr').each(function (i) {
                var $tds = $(this).find('td'),
                    checkItemObservation = $tds.eq(5).find('input').val()
                if (typeof checkItemObservation != "undefined") {
                    
                    
                    var PartsId = $tds.eq(0).text().trim();
                    debugger;
                     if($('#' + PartsId).is(':checked'))
                    {
                          Result = true;
                     }
                    else
                     {
                         Result = false;
                     }

                    var Remarks = $tds.eq(6).find('input').val();

                    if (Result == null)
                    {
                        
                            $tds.eq(5).find('input').val("");
                            $('#' + PartsId).css("border", '1px solid red');
                         
                    }
                    else
                    {
                        $('#' + PartsId).css("border", '1px solid green');
                    }

                    if (Remarks == null) {

                        $tds.eq(6).find('input').val("");
                        $('#' + PartsId).css("border", '1px solid red');

                    }
                    else {
                        $('#' + PartsId).css("border", '1px solid green');
                    }

                } 





                if ((Result == true || (Result == true && Remarks != ""))) {
                    CheckListResult[J] = {
                        'PartsId': PartsId, 'Result': Result, 'Remarks': Remarks
                    };
                    J++;
                }
                i++;
            });

            var reqListObj = new Object();
            reqListObj.CheckListMaintenanceResults = CheckListResult;
            reqListObj.LineId = LineId;
            reqListObj.DRILeader = DRILeader;
            reqListObj.LineLeader = LineLeader;

            if (CheckListResult.length > 0) {
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/MaintenanceChecklsit/SaveMaintenanceChecklist",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                        //   window.location.reload();
                        $("#btnSearch").click();
                    },
                    error: function () {
                        // alert('error');
                    }

                })
            }
            else {
                alert("Alteast one Part needed for Creating TO Request");
            }
        } else {
            alert("Please Select LineId");
        }
    }

    //$(document).ready(function () {
    //    debugger;

    //        var LineId = $("#LineId").val();

    //        if (LineId != 0)
    //        $("#btnSearch").click();

    //});

</script>


