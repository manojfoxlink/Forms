    function openUploadDialog(leave, employeeid) {
        debugger

        $.ajax({
            type: "POST",
            contentType: "application/json; charset=utf-8",
            url: "/WorkFlow/FlowTask",
            data: '{ Leaveid:"' + leave + '", empId:"' + employeeid + '" }',
            dataType: "html",
            success: function (data) {
                $('#dialog-upload').html(data);
            },
            error: function () {
                // alert('error');
            }

        })
        dialogOpen();
    }
    function dialogOpen() {
        $("#dialog-upload").dialog({
            modal: false,
            width: 600,
            height: 800,
            buttons: {
                //Submit: function () {
                //    //var obj = new Object();
                //    //obj.DocId = $('#hdnDocId').val();
                //    //obj.ProjectId = $('#hdnProjectId').val();
                //    //obj.CategoryID = $('#hdnCategoryId').val();
                //    //obj.SubCategoryID = $('#hdnSubCategoryId').val();
                //    //obj.ChildCategoryID = $('#hdnChildCategoryId').val();
                //    //obj.DocumentName = $('#txtDocName').val();
                //    //obj.Filepath = $('#hdnFilepath').val();

                //    //submitDocument(obj);
                //},
                Cancel: function () {
                    $(this).dialog("close");
                }
            }
        });
    }
    $(function () {
        $('#selectAll').click(function () {
            debugger;
            if (this.checked) {
                $(".checkboxes").prop("checked", true);
            } else {
                $(".checkboxes").prop("checked", false);
            }
        });
    });

    function Approval() {
        debugger;

        //   showLoader();
        // var Qurey = $("#Qurey").val();

        var isflag = false;
        var WorkFlowViewModel = [];

        var J = 0;
        var table = $("#example1 tbody");

        table.find('tr').each(function (i) {
            var $tds = $(this).find('td');
            var id = $tds.eq(0).text().trim();

            var isflageach = false;
            if ($('#' + id).is(':checked')) {
                isflag = true;
                isflageach = true;
            }
            debugger;
            if (isflageach) {
                debugger;
                //$('#LeaveType' + id).css("border", '1px solid green');
                $('#Reason' + id).css("border", '1px solid green');
                var Pid = $tds.eq(0).text().trim();
                var ResultId = $tds.eq(1).text().trim();
                var MenuId = $tds.eq(2).text().trim();
                var SectionId = $tds.eq(3).text().trim();
                var TaskId = $tds.eq(4).text().trim();
                var ApproveId = $tds.eq(5).text().trim();
                var Remark = $tds.eq(21).find('input').val();
                var Query = $tds.eq(20).find('input').val();

                WorkFlowViewModel[J] = {
                    'Pid': Pid, 'ResultId': ResultId, 'MenuId': MenuId, 'SectionId': SectionId, 'TaskId': TaskId, 'ApproveId': ApproveId, 'Reason': Query, 'Remark': Remark
                };
                J++;
            }
        });

        if (isflag) {
            var reqListObj = new Object();
            reqListObj.viewModelsResult = WorkFlowViewModel;

            if (WorkFlowViewModel.length > 0) {
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/CheckList/HotBarApprove",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                        window.location.reload();
                    },
                    error: function () {
                        // alert('error');
                    }
                })
            }
            else {
                alert("At least one checkbox needs to be selected");
            }
        } else {
            alert("Please select at least one checkbox");
            return false;
        }
    }




    function Rejected() {
        debugger;

        var Qurey = $("#Qurey").val();

        var isflag = false;
        var WorkFlowViewModel = [];

        var J = 0;
        var table = $("#example1 tbody");

        table.find('tr').each(function (i) {
            var $tds = $(this).find('td');
            var id = $tds.eq(0).text().trim();

            var isflageach = false;
            if ($('#' + id).is(':checked')) {
                isflag = true;
                isflageach = true;
            }
            if (isflageach) {
                debugger;
                //$('#LeaveType' + id).css("border", '1px solid green');
                $('#Reason' + id).css("border", '1px solid green');
                var Pid = $tds.eq(0).text().trim();
                var ResultId = $tds.eq(1).text().trim();
                var MenuId = $tds.eq(2).text().trim();
                var SectionId = $tds.eq(3).text().trim();
                var TaskId = $tds.eq(4).text().trim();
                var ApproveId = $tds.eq(5).text().trim();
                var Remark = $tds.eq(21).find('input').val();
                var Query = $tds.eq(20).find('input').val();

                WorkFlowViewModel[J] = {
                    'Pid': Pid, 'ResultId': ResultId, 'MenuId': MenuId, 'SectionId': SectionId, 'TaskId': TaskId, 'ApproveId': ApproveId, 'Reason': Query, 'Remark': Remark
                };
                J++;
            }
        });

        if (isflag) {
            var reqListObj = new Object();
            reqListObj.viewModelsResult = WorkFlowViewModel;

            if (WorkFlowViewModel.length > 0) {
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/CheckList/HotBarReject",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                        window.location.reload();
                    },
                    error: function () {
                        // alert('error');
                    }
                })
            } else {
                alert("At least one checkbox needed to be selected");
            }
        } else {
            alert("Please select at least one checkbox");
            return false;
        }
    }

</script>
