@model ChecklistForm.Models.WorkFlowViewModel
@{
    ViewBag.Title = "HotBarTodoTask";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    table {
        overflow-y: scroll; /* Always show vertical scrollbar */
        overflow-x: auto; /* Show horizontal scrollbar when needed */
    }

    .padding {
        padding: 10px;
    }

    #example1_wrapper {
        overflow: auto;
    }
</style>
<div class="box box-solid box-default">
    <div class="box-header">
        <h3 class="box-title">HOTBAR Checklist FACA</h3>
        <div class="box-tools pull-right">
            <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                <i class="fa fa-minus"></i>
            </button>
        </div>
    </div>

    <div class="box-body ">
        @using (Html.BeginForm("HotBarTodoTask", "CheckList", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form", onsubmit = "showLoader(this);" }))
        {
            @Html.AntiForgeryToken()

            {
                Html.RenderPartial("_ErrorMessage");
            }

            <div class="box padding ">
                @*<div class="row" style="padding-top:15px">
                        <div class="col-lg-10 col-md-12 col-sm-12 col-xs-12">
                            <div class="form-group">
                                <div class="row">
                                    <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                        @Html.DropDownListFor(model => model.MenuId, new SelectList(Model.Menuss, "MenuId", "Menu", 0), "--select Menu--", new { @class = "form-control", required = "required" })


                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>*@
                <table id="example1" class="table table-bordered table-hover" role="grid" aria-describedby="example1_info">
                    <thead>
                        <tr role="row">
                            <td style="display:none;">
                                Pid
                            </td>
                            <td style="display:none;">
                                ResultId
                            </td>
                            <td style="display:none;">
                                MenuId
                            </td>
                            <td style="display:none;">
                                SectionId
                            </td>
                            <td style="display:none;">
                                TaskId
                            </td>
                            <td style="display:none;">
                                ApproveId
                            </td>
                            <th>
                                <input type="checkbox" id="selectAll" name="selectAll" />
                            </th>

                            @*<th>
                                    Machine
                                </th>*@
                            <th>
                                Work Station
                            </th>
                            <th>
                                Inspection Project
                            </th>
                            <th>
                                Inspection Specifications
                            </th>
                            <th>
                                Frequency
                            </th>
                            <th>
                                Value 1
                            </th>
                            <th>
                                Value 2
                            </th>
                            <th>
                                Value 3
                            </th>
                            <th>
                                Value 4
                            </th>
                            <th>
                                Value 5
                            </th>
                            <th>
                                Inspection Results
                            </th>
                            <th>
                                Root Cause
                            </th>
                            <th>
                                Preventive Action
                            </th>
                            <th>
                                Corrective Action
                            </th>
                            @if (Model.WorkFlowList != null && Model.WorkFlowList.Rows.Count > 0 && Convert.ToInt32(Model.WorkFlowList.Rows[0]["TaskId"]) == 40)
                            {
                                <th>
                                    Validation
                                </th>
                                <th>
                                    Remarks
                                </th>
                            }
                            @if (Model.WorkFlowList != null && Model.WorkFlowList.Rows.Count > 0 && Convert.ToInt32(Model.WorkFlowList.Rows[0]["TaskId"]) != 40)
                            {
                                <th>
                                    Validation
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>

                        @foreach (System.Data.DataRow binRow in Model.WorkFlowList.Rows)
                        {
                            <tr>

                                <td style="display:none;">

                                    @binRow["Pid"].ToString()
                                </td>
                                <td style="display:none;">

                                    @binRow["ResultId"].ToString()
                                </td>
                                <td style="display:none;">

                                    @binRow["MenuId"].ToString()
                                </td>
                                <td style="display:none;">

                                    @binRow["SectionId"].ToString()
                                </td>
                                <td style="display:none;">

                                    @binRow["TaskId"].ToString()
                                </td>
                                <td style="display:none;">

                                    @binRow["ApproveId"].ToString()
                                </td>
                                <td>
                                    <input type="checkbox" id="@binRow["Pid"].ToString()" class="checkboxes" name="chk" value="@binRow["ResultId"].ToString()" />
                                </td>
                                @*<td>
                                        @binRow["Machine"].ToString()
                                    </td>*@
                                <td>

                                    @binRow["WorkStation"].ToString()
                                </td>

                                <td>
                                    @binRow["InspectionProject"].ToString()
                                </td>

                                <td>
                                    @binRow["InspectionSpecifications"].ToString()
                                </td>

                                <td>

                                    @binRow["Frequency"].ToString()
                                </td>
                                <td>
                                    @binRow["Value1"].ToString()
                                </td>

                                <td>
                                    @binRow["Value2"].ToString()
                                </td>

                                <td>

                                    @binRow["Value3"].ToString()

                                </td>
                                <td>
                                    @binRow["Value4"].ToString()
                                </td>

                                <td>
                                    @binRow["Value5"].ToString()

                                </td>
                                <td>
                                    @binRow["InspectionResults"].ToString()

                                </td>
                                <td>
                                    @binRow["RootCause"].ToString()
                                </td>
                                <td>
                                    @binRow["PreventiveAction"].ToString()
                                </td>
                                <td>
                                    @binRow["CorrectiveAction"].ToString()
                                </td>
                                @if (binRow["TaskId"] != DBNull.Value && Convert.ToInt32(binRow["TaskId"]) == 40)
                                {
                                    <td>
                                        @binRow["Queryy"].ToString()
                                    </td>
                                    <td>
                                        <input type="text" class="form-control" name="Remark" id="@binRow["ResultId"].ToString()" />
                                    </td>
                                }

                                @if (binRow["TaskId"] != DBNull.Value && Convert.ToInt32(binRow["TaskId"]) != 40)
                                {
                                    <td>
                                        <input type="text" class="form-control" name="Query" id="@binRow["ResultId"].ToString()" />
                                    </td>

                                }



                            </tr>


                        }
                    </tbody>
                    <tfoot>

                    </tfoot>

                </table>
            </div>
            @*<div class="row padding">

                


                <div class="col-lg-offset-3 col-md-3 col-sm-2 col-xs-0">


                    <label>Validation</label>
                    <textarea class="form-control" rows="3" placeholder="Enter ..." spellcheck="false" id="Qurey"></textarea>

                </div>
                <div class="col-lg-2 col-md-2 col-sm-2 col-xs-4">

                </div>
            </div>*@

            <div class="row padding">

                <div class="col-lg-2 col-md-2 col-sm-2 col-xs-0">
                </div>

                <div class="col-lg-2 col-md-2 col-sm-2 col-xs-4">

                </div>
                <div class="col-lg-4 col-md-2 col-sm-2 col-xs-0">
                    <button type="button" id="Approve" onclick="Approval()" class="btn btn-primary btn-outline-primary">Approve</button>
                    <button type="button" id="Reject" onclick="Rejected()" class="btn btn-danger btn-outline-danger">Reject</button>

                    @*<button type="button" id="Approve" onclick="Approval()" class="btn btn-primary">Approve</button>
                        <button type="button" id="Reject" onclick="Rejected()" class="btn btn-danger">Reject</button>*@
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4 col-xs-1">

                </div>

            </div>

        }
    </div>
</div>





<div id="dialog-upload" title="Upload Images" style="display:none;" class="form-control">


</div>

<link href="~/Content/jquery-ui-1.12.1.css" rel="stylesheet" />
<script src="~/Scripts/jquery-ui-1.12.2.min.js"></script>


<script>
