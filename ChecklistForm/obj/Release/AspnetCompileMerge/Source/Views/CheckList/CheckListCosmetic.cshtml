                            $tds.eq(2).find('input').val("");
                            $('#' + DefectId).css("border", '1px solid red');
                        } else {
                            $('#' + DefectId).css("border", '1px solid green');
                        }
                    }
                    
                }

                if ((DefectId != 0 && Value != 0)) {
                    CheckListResult[J] = {
                        'DefectId': DefectId, 'Value': Value
                    };
                    J++;
                }



            });
            var reqListObj = new Object();
            reqListObj.CheckListCosmeticResults = CheckListResult;
            reqListObj.LineId = LineId;
            reqListObj.ProjectId = ProjectId;
            reqListObj.ProdLineLeader = ProdLineLeader;
            reqListObj.CheckedBy = CheckedBy;
            reqListObj.ApprovedBy = ApprovedBy;
            reqListObj.ModelId = ModelId;
            reqListObj.PartId = PartId;
            if (CheckListResult.length > 0) {
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/CheckList/SaveCheckListCosmetic",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                        //window.location.reload();
                        $("#btnSearch").click();
                    },
                    error: function () {
                        // alert('error');
                    }

                })
            }

            else {
                alert("Alteast one Part needed for Creating TO Request");
            }
        } else {
            alert("Please Select LineId");
        }
    }

