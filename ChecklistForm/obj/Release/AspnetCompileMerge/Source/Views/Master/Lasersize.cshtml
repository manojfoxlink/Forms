@model ChecklistForm.Models.LaserViewModel
@{
    ViewBag.Title = "Lasersize";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    Html.RenderPartial("_ErrorMessage");
}

@using (Html.BeginForm("Lasersize", "Master", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form",required = "required"}))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true)

    <div class="box box-solid box-warning">
        <div class="box-header">

            <div class="box-tools pull-right">
                <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                    <i class="fa fa-minus"></i>
                </button>
            </div>
        </div>

        <div class="box-body">

            <div class="register-box">
                <div class="register-logo">
                    @*<a href="../Home/Index"><b>Create a NEW Project</b>User</a>*@
                    <a href="#"><b>Lasersize Creation</b></a>
                </div>
                <div class="row">

                    @*<div class="form-group has-feedback">
                            @Html.DropDownListFor(x => x.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "--select Project--", new { @class = "form-control" })

                        </div>*@

                    @*<div class="col-lg-2 col-md-3 col-sm-1 col-xs-12">

                            <button type="submit" class="btn btn-success" name="Command" value="Search" id="btnSearch">Search</button>
                        </div>*@
                </div>

                <div class="register-box-body">

                    <form action=".." method="post">
                        <div class="form-group has-feedback">

                                @Html.DropDownListFor(model => model.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "Select Project", new { @class = "form-control select2", @style = "width: 100%", required = "required" })
                                @Html.ValidationMessageFor(model => model.ProjectId, "", new { @class = "text-danger" })
                                <span class="glyphicon glyphicon-user form-control-feedback"></span>

                            </div>

                        <div class="form-group has-feedback">


                            @Html.TextBoxFor(x => x.Locations, new { placeholder = "Locations", @class = "form-control", autocomplete = "off",@required=true })
                            @Html.ValidationMessageFor(model => model.Locations, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>


                        <div class="form-group has-feedback">


                            @Html.TextBoxFor(x => x.Specification, new { placeholder = "Specification", @class = "form-control", autocomplete = "off", @required = true })
                            @Html.ValidationMessageFor(model => model.Specification, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        <div class="form-group has-feedback">


                            @Html.TextBoxFor(x => x.Minimum, new { placeholder = "Minimum", @class = "form-control", autocomplete = "off",@required=true})
                            @Html.ValidationMessageFor(model => model.Minimum, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>


                        <div class="form-group has-feedback">


                            @Html.TextBoxFor(x => x.Maximum, new { placeholder = "Maximum", @class = "form-control", autocomplete = "off",@required =true })
                            @Html.ValidationMessageFor(model => model.Maximum, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>



                        <div class="row">
                            <div class="col-xs-4">

                            </div>
                            <div class="col-xs-4">
                                <button type="submit" class="btn btn-success btn-block btn-flat">Submit</button>
                            </div>

                            <!-- /.col -->
                            <div class="col-xs-4">

                            </div>
                            <!-- /.col -->
                        </div>
                        <div class="row">
                            <div class="col-xs-2">

                            </div>
                            <div class="col-xs-8">
                                <h3 class="text-danger">@ViewBag.ResultMessage</h3>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-2">

                            </div>
                            <!-- /.col -->
                        </div>
                    </form>




                </div>
                <!-- /.form-box -->
            </div>
        </div><!-- /.box-body -->
    </div>

    <script>

    </script>






}



