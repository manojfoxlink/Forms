@model ChecklistForm.Models.CTQPartsToInspectModelView
@{
    ViewBag.Title = "CTQPartsToInspect";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    Html.RenderPartial("_ErrorMessage");
}

@using (Html.BeginForm("CTQPartsToInspect", "Master", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true)




    <div class="box box-solid box-warning">
        <div class="box-header">
            @*<h3 class="box-title">Create New ID</h3*@>
            <div class="box-tools pull-right">
                <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                    <i class="fa fa-minus"></i>
                </button>
            </div>
        </div><!-- /.box-header -->
        <div class="box-body">

            <div class="register-box">
                <div class="register-logo">
                    <a href="#"><b>CTQ PartToInspection Creation</a>
                </div>

                <div class="register-box-body">
                    @*<p class="login-box-msg">Register a new membership</p>*@

                    <form action=".." method="post">
                        <div class="form-group has-feedback">

                            @Html.DropDownListFor(model => model.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "Select Project", new { @class = "form-control select2", @style = "width: 100%", onchange = "ddlGetSectionByProject()", required = "required" })
                            @Html.ValidationMessageFor(model => model.ProjectId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>

                        <div class="form-group has-feedback">

                            @Html.DropDownListFor(model => model.SectionId, new SelectList(Model.Sections, "SectionId", "Section", 0), "--select Section--", new { @class = "form-control select2", @style = "width: 100%", required = "required" })
                            @Html.ValidationMessageFor(model => model.SectionId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>

                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.SNo, new { placeholder = "SNo", @class = "form-control", autocomplete = "off", @required = "required" })
                            @Html.ValidationMessageFor(model => model.SNo, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        @*<div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.Section, new { placeholder = "Section", @class = "form-control", autocomplete = "off" })
                            @Html.ValidationMessageFor(model => model.Section, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>*@

                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.PartToInspect, new { placeholder = "Part To Inspect", @class = "form-control", autocomplete = "off", @required = "required" })
                            @Html.ValidationMessageFor(model => model.PartToInspect, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        <div class="row">
                            <div class="col-xs-4">

                            </div>
                            <div class="col-xs-4">
                                <button type="submit" class="btn btn-success btn-block btn-flat">Submit</button>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-4">

                            </div>
                            <!-- /.col -->
                        </div>
                        <div class="row">
                            <div class="col-xs-2">

                            </div>
                            <div class="col-xs-8">
                                <h3 class="text-danger">@ViewBag.ResultMessage</h3>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-2">

                            </div>
                            <!-- /.col -->
                        </div>
                    </form>




                </div>
                <!-- /.form-box -->
            </div>
        </div><!-- /.box-body -->
    </div>
    <script>

    </script>

}