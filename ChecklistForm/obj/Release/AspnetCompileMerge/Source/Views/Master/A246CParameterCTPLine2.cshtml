@model ChecklistForm.Models.A246CParameterCTPOneViewModel
@{
    ViewBag.Title = "A246CParameterCTPLine2";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    Html.RenderPartial("_ErrorMessage");
}
@using (Html.BeginForm("A246CParameterCTPLine2", "Master", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true)


    <div class="box box-solid box-warning">
        <div class="box-header">
            @*<h3 class="box-title">Create New ID</h3*@>
            <div class="box-tools pull-right">
                <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                    <i class="fa fa-minus"></i>
                </button>
            </div>
        </div><!-- /.box-header -->
        <div class="box-body">

            <div class="register-box">
                <div class="register-logo">
                    <a href="#"><b>A246C CTP Parameter For Line-2</b></a>
                </div>

                <div class="register-box-body">
                    @*<p class="login-box-msg">Register a new membership</p>*@

                    <form action=".." method="post">
                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(x => x.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "--select Project--", new { @class = "form-control", onchange = "ddlA246CMachinesByProject();", required = "true" })
                            @Html.ValidationMessageFor(model => model.ProjectId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>
                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(x => x.MachineId, new SelectList(Model.Machines, "MachineId", "Machine", 0), "--select Machine--", new { @class = "form-control", onchange = "ddlA246CStationCTPOneByMachine();", required = "true" })
                            @Html.ValidationMessageFor(model => model.MachineId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>
                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(x => x.StationId, new SelectList(Model.Stations, "StationId", "StationName", 0), "--select Station--", new { @class = "form-control", required = "true" })
                            @Html.ValidationMessageFor(model => model.StationId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>
                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.ParameterName, new { placeholder = "Parameter", @class = "form-control", autocomplete = "off", @required = "true" })
                            @Html.ValidationMessageFor(model => model.ParameterName, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.Unit, new { placeholder = "Unit", @class = "form-control", autocomplete = "off", @required = "true" })
                            @Html.ValidationMessageFor(model => model.Unit, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.LSL, new { placeholder = "LSL", @class = "form-control", autocomplete = "off", @required = "true" })
                            @Html.ValidationMessageFor(model => model.LSL, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.USL, new { placeholder = "USL", @class = "form-control", autocomplete = "off", @required = "true" })
                            @Html.ValidationMessageFor(model => model.USL, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>

                        <div class="row">
                            <div class="col-xs-4">

                            </div>
                            <div class="col-xs-4">
                                <button type="submit" class="btn btn-success btn-block btn-flat">Submit</button>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-4">

                            </div>
                            <!-- /.col -->
                        </div>
                        <div class="row">
                            <div class="col-xs-2">

                            </div>
                            <div class="col-xs-8">
                                <h3 class="text-danger">@ViewBag.ResultMessage</h3>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-2">

                            </div>
                            <!-- /.col -->
                        </div>
                    </form>




                </div>
                <!-- /.form-box -->
            </div>
        </div><!-- /.box-body -->
    </div>





}
