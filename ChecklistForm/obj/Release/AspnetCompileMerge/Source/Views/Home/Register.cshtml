@model ChecklistForm.Models.RegisterModel

@{
    ViewBag.Title = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    Html.RenderPartial("_ErrorMessage");
}

@using (Html.BeginForm("Register", "Home", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form", onsubmit = "showLoader(this);" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(false)
    <div class="box box-solid box-warning">
        <div class="box-header">
            <h3 class="box-title">Create New ID</h3>
            <div class="box-tools pull-right">
                <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                    <i class="fa fa-minus"></i>
                </button>
            </div>
        </div><!-- /.box-header -->
        <div class="box-body">

            <div class="register-box">
                <div class="register-logo">
                    <a href="../Home/Index"><b>Create a NEW </b>User</a>
                </div>

                <div class="register-box-body">
                    <p class="login-box-msg">Register a new membership</p>

                    <form action=".." method="post">
                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(model => model.UserId, new { placeholder = "User ID", @class = "form-control" })

                            @Html.ValidationMessageFor(model => model.UserId, "", new { @class = "text-danger" })

                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>
                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(model => model.UserName, new { placeholder = "Full Name", @class = "form-control" })
                            @Html.ValidationMessageFor(model => model.UserName)
                            <span class="glyphicon glyphicon-envelope form-control-feedback"></span>
                        </div>
                        <div class="form-group has-feedback">
                            @Html.PasswordFor(model => model.Password, new { placeholder = "Password", @class = "form-control" })
                            @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-lock form-control-feedback"></span>
                        </div>
                        <div class="form-group has-feedback">
                            @Html.PasswordFor(model => model.ConfirmPassword, new { placeholder = "Confirm Password", @class = "form-control" })
                            @Html.ValidationMessageFor(model => model.ConfirmPassword, "", new { @class = "text-danger" })

                            <span class="glyphicon glyphicon-log-in form-control-feedback"></span>
                        </div>
                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(model => model.Designation, new { placeholder = "Designation", @class = "form-control" })

                            <span class="glyphicon glyphicon-log-in form-control-feedback"></span>
                        </div>
                        <div class="form-group has-feedback">
                            Admin:@Html.RadioButtonFor(m => m.RoleName, "Admin")
                            User: @Html.RadioButtonFor(m => m.RoleName, "User")
                        </div>
                        <div class="form-group has-feedback">
                            <input type="file" name="file" id="file" />
                        </div>
                        <div class="row">
                            <div class="col-xs-4">

                            </div>
                            <div class="col-xs-4">
                                <button type="submit" class="btn btn-success btn-block btn-flat">Register</button>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-4">

                            </div>
                            <!-- /.col -->
                        </div>
                        <div class="row">
                            <div class="col-xs-2">

                            </div>
                            <div class="col-xs-8">
                                <h3 class="text-danger">@ViewBag.ResultMessage</h3>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-2">

                            </div>
                            <!-- /.col -->
                        </div>
                    </form>




                </div>
                <!-- /.form-box -->
            </div>
        </div><!-- /.box-body -->
    </div>

}

<div class="box box-solid box-warning">
    <div class="box-header">
        <h3 class="box-title">Search For Employee</h3>
        <div class="box-tools pull-right">
            <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                <i class="fa fa-minus"></i>
            </button>
        </div>
    </div>
    <div class="box-body">
        @using (Html.BeginForm("SearchForEmployee", "Home", new { option = 2 }))
        {
            <div class="box padding">
                <div class="row padding">
                    <div class="col-xs-4">
                        @Html.TextBoxFor(model => model.UserId, new { placeholder = "Enter Employee Number..", @class = "form-control" })
                    </div>
                    <div class="col-xs-4">
                        @Html.TextBoxFor(model => model.UserName, new { placeholder = "Enter Employee Name..", @class = "form-control" })
                    </div>
                    <div class="col-xs-4">
                        <button type="submit" class="btn btn-primary btn-flat">Search</button>
                    </div>
                </div>

            </div>
        }

        <div class="box padding">
            <table id="example1" class="table table-bordered table-hover dataTable" role="grid" aria-describedby="example2_info">
                <thead>
                    <tr role="row">
                        <th>Employee Number</th>
                        <th>Employee Name</th>
                        <th>Role</th>
                        <th>Action</th>
                </thead>
                <tbody>
                    @foreach (System.Data.DataRow empRow in Model.EmployeeList.Rows)
                    {
                        <tr role="row" class="odd">
                            <td class="sorting_1">@empRow["EmpNumber"].ToString()</td>
                            <td>@empRow["Name"].ToString()</td>
                            <td>@empRow["RoleName"].ToString()</td>
                            <td><button type="button" onclick="delEmp('@empRow["EmpNumber"].ToString()','@empRow["RoleName"].ToString()')" class="btn btn-danger btn-flat">Delete</button></td>
                        </tr>
                    }
                </tbody>
                <tfoot>

                </tfoot>
            </table>
        </div>

    </div>

</div>

<style>
    .padding {
        padding: 10px;
    }
</style>
<script>
    function delEmp(empNum, role) {
        var r = confirm("Are you Sure..\n You want to Delete (" + empNum + " )");
        if (r == true) {
            // alert(empNum+'--'+role);
            $.ajax({
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: "DeleteEmployee",
                data: JSON.stringify({ EmpNumber: empNum, roleName: role }),
                success: function (data) {
                    alert(data);
                    location.reload();
                }
            })
        }

    }
</script>