@model ChecklistForm.Models.ProdCheckListQualityAuditModelView
@{
    ViewBag.Title = "ProdQualityAuditChecklistWith5S";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    Html.RenderPartial("_ErrorMessage");
}
<style>
    .padding {
        padding: 10px;
    }

    .table-container {
        max-height: 500px; /* Adjust as needed */
        overflow-y: auto; /* Enables vertical scrolling */
        border: 1px solid #ccc;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
    }

        .table thead th {
            position: sticky;
            top: 0;
            background-color: #f9f9f9; /* Optional: Background color */
            z-index: 10; /* Keeps the header on top */
            border-bottom: 1px solid #ddd;
            padding: 10px;
            text-align: left;
        }

        .table tbody td {
            padding: 10px;
            border-bottom: 1px solid #ddd;
        }

    .custom-dropdown {
        width: 80px;
        height: 34px;
    }
</style>
@using (Html.BeginForm("ProdQualityAuditChecklistWith5S", "CheckList", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
{
    <div class="box box-solid box-default">
        <div class="box-header">

            <h3 class="box-title">A246C LINE IMPROVEMENT ACTIVITIES AUDIT SHEET WITH 5S</h3>
        </div><!-- /.box-header -->
        <div class="box-body">

            <div class="box padding">
                <div class="row" style="padding-top:15px">
                    <div class="col-lg-10 col-md-12 col-sm-12 col-xs-12">

                        <div class="form-group">
                            <div class="row">

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.LineId, new SelectList(Model.Lines, "LineId", "LineName", 0), "--select Line--", new { @class = "form-control", required = "required" })


                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "--select Project--", new { @class = "form-control", onchange = "ddlBatchByProjectCheckList();", required = "required" })


                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.BatchId, new SelectList(Model.Batches, "BatchId", "BatchName", 0), "--select Batch--", new { @class = "form-control", onchange = "ddlZoneByBatchCheckList();", required = "required" })


                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.ZoneId, new SelectList(Model.Zones, "ZoneId", "ZoneName", 0), "--select Zone--", new { @class = "form-control", onchange = "ddlProdModuleByProjectCheckList();ddlProductionLineLeaderByBatch();", required = "required" })


                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.ModuleId, new SelectList(Model.Modules, "ModuleId", "Module", 0), "--select Station--", new { @class = "form-control", required = "required" })


                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.DropDownListFor(model => model.ProdId, new SelectList(Model.LineLeaders, "ProdId", "LineLeader", 0), "--select Production Line Leader--", new { @class = "form-control", required = "required" })


                                </div>
                                @*<div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                        @Html.DropDownListFor(model => model.ModelId, new SelectList(Model.ModelNos, "ModelId", "Model", 0), "--Select Model--", new { @class = "form-control", onchange = "ddlGetPartNoByModel()", required = "required" })

                                        <span class="glyphicon glyphicon-user form-control-feedback"></span>
                                    </div>
                                    <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                        @Html.DropDownListFor(model => model.PartId, new SelectList(Model.PartNos, "PartId", "Part", 0), "--Select Part--", new { @class = "form-control", required = "required" })

                                        <span class="glyphicon glyphicon-user form-control-feedback"></span>
                                    </div>*@
                                @*<div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                        @Html.TextBoxFor(x => x.ProdLineLeader, new { placeholder = "Production LineLeader", @class = "form-control", autocomplete = "off", @required = true })
                                    </div>*@
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.ShiftLeader, new { placeholder = "Shift Leader", @class = "form-control", autocomplete = "off", @required = true })
                                </div>

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.CheckedBy, new { placeholder = "Checked By", @class = "form-control", autocomplete = "off", @required = true })
                                </div>

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.VerifiedBy, new { placeholder = "Verified By", @class = "form-control", autocomplete = "off", @required = true })
                                </div>

                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.ApprovedBy, new { placeholder = "Approved By", @class = "form-control", autocomplete = "off", @required = true })
                                </div>
                                <div class="col-lg-4 col-md-3 col-sm-4 col-xs-12">
                                    @Html.TextBoxFor(x => x.AuditedBy, new { placeholder = "Audited By", @class = "form-control", autocomplete = "off", @required = true })
                                </div>

                                <div class="col-lg-2 col-md-3 col-sm-1 col-xs-12">

                                    <button type="submit" class="btn btn-success" name="Command" value="Search" id="btnSearch">Search</button>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <div class="box padding">
                <div class="row table-container">
                    <table class="table table-bordered table-hover" role="grid" aria-describedby="example3_info" id="QuastionTable">
