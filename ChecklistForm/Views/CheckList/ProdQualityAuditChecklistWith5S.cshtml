                                        </b>
                                        <br />
                                        <b>
                                            Fail Sample indicates good. it must be NG.
                                        </b>
                                        <br />
                                        <b>
                                            Fail Sample indicates abnormal. it must be OK.
                                        </b>

                                    </td>
                                </tr>*@
                            <tr role="row">
                                <th style="display:none">
                                    RiskId
                                </th>
                                <th style="display:none">
                                    Process No
                                </th>

                                <th>
                                    Station Name
                                </th>
                                <th>
                                    Activity Description
                                </th>
                                <th style="display:none">
                                    Sampling Units
                                </th>
                                <th style="display:none">
                                    DRI
                                </th>
                                <th style="display:none">
                                    Status
                                </th>
                                <th>
                                    1S
                                </th>
                                <th>
                                    2S
                                </th>
                                <th>
                                    3S
                                </th>
                                <th>
                                    4S
                                </th>
                                <th>
                                    5S
                                </th>
                                <th>
                                    Remarks
                                </th>
                                <th>
                                    Upload
                                </th>
                                <th>
                                    Action
                                </th>
                                <th style="display:none">
                                    Image
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
    int row = 1;
    int TotalCount = 0;

    //int row2 = 1;
    //int TCount = 0;

    //int row3 = 1;
    //int TCount2 = 0;
                            }

                            @foreach (System.Data.DataRow item in Model.dtChecklist.Rows)
                            {
                                <tr>
                                    @{
                                TotalCount = (Int32)@item["TotalCount"];
                                //TCount = (Int32)@item["TCount"];
                                //TCount2 = (Int32)@item["TCount2"];
                                    }


                                    <td style="display:none">
                                        @item["RiskId"].ToString()
                                    </td>


                                    @if (row > (Int32)item["TotalCount"])
                                    {
                                        row = 1;


                                    }
                                    @*@if (row2 > (Int32)item["TCount"])
                                        {
                                            row2 = 1;


                                        }
                                        @if (row3 > (Int32)item["TCount2"])
                                        {
                                            row3 = 1;


                                        }*@


                                    @if (row == 1)
                                    {
                                        <td rowspan="@TotalCount" style="display:none">
                                            @item["Module"].ToString()
                                        </td>

                                        <td rowspan="@TotalCount">
                                            @item["Module"].ToString()
                                        </td>
                                    }

                                    @*@if (row2 == 1)
                                        {
                                            <td rowspan="@TCount">
                                                @item["Inspection"].ToString()
                                            </td>
                                        }
                                        @if (row3 == 1)
                                        {
                                            <td rowspan="@TCount2">

                                                @item["Frequency"].ToString()

                                            </td>
                                        }*@

                                    <td>
                                        @item["Points"].ToString()
                                    </td>
                                    <td style="display:none">
                                        @item["Module"].ToString()
                                    </td>
                                    <td style="display:none">
                                        @item["Dept"].ToString()
                                    </td>
                                    <td style="display:none">
                                        @Html.DropDownListFor(model => model.StatusId, new SelectList(Model.Statuses, "StatusId", "Status", 0), "--Select Status--", new { @class = "form-control", })
                                    </td>
                                    <td>
                                        <input type="checkbox" name="OneS" id="@item["RiskId"].ToString()" />
                                    </td>
                                    <td>
                                        <input type="checkbox" name="TwoS" id="@item["RiskId"].ToString()" />
                                    </td>
                                    <td>
                                        <input type="checkbox" name="ThreeS" id="@item["RiskId"].ToString()" />
                                    </td>
                                    <td>
                                        <input type="checkbox" name="FourS" id="@item["RiskId"].ToString()" />
                                    </td>
                                    <td>
                                        <input type="checkbox" name="FiveS" id="@item["RiskId"].ToString()" />
                                    </td>
                                    @*<td>
                                            <input type="text" class="form-control" name="Sampling" />
                                        </td>*@
                                    <td>
                                        <input type="text" class="form-control custom-dropdown" name="Namee" id="@item["RiskId"].ToString()" />
                                    </td>


                                    @*<td>
                                            <input type="text" class="form-control custom-dropdown" name="Result" id="@item["RiskId"].ToString()/>
                                        </td>*@
                                    <td>
                                        <input class="form-control" type="file" name="Image" id="FileUpload1-@item["RiskId"].ToString()" />
                                        <input class="btn btn-success" id="btnUpload-@item["RiskId"].ToString()" type="button" style="margin:5px;" onclick="uploadFile(@item["RiskId"].ToString())" value="Upload" />
                                        <label id="lblUploadStatu-@item["RiskId"].ToString()"></label>
                                    </td>
                                    <td>
                                        <button type="button" name="Command" id="btnSave" onclick="Save()" value="SUMBIT" class="btn btn-primary btn-flat">Save</button>
                                    </td>
                                    <td style="display:none">
                                        <input type="text" id="Path-@item["RiskId"].ToString()" />
                                    </td>

                                    @if (row == TotalCount)
                                    {
                                        row = 1;
                                    }
                                    else
                                    {
                                        row += 1;
                                    }

                                    @*@if (row2 == TCount)
                                        {
                                            row2 = 1;
                                        }
                                        else
                                        {
                                            row2 += 1;
                                        }

                                        @if (row3 == TCount)
                                        {
                                            row3 = 1;
                                        }
                                        else
                                        {
                                            row3 += 1;
                                        }*@

                                </tr>



                            }


                        </tbody>
                        <tfoot>

                        </tfoot>

                    </table>

                </div>

                <div class="row padding">
                    <div class="col-xs-10 right">

                        <button type="button" name="Command" id="btnSave" onclick="Save()" value="SUMBIT" class="btn btn-primary btn-flat">Submit</button>


                    </div>

                </div>
            </div>
        </div>
    </div>
}

