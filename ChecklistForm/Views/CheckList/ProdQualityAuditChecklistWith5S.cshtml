    function Save() {
        var CheckListResult = [];
        var table = $("table tbody");
        var LineId = $("#LineId").val();
        var ProjectId = $("#ProjectId").val();
        var BatchId = $("#BatchId").val();
        var ZoneId = $("#ZoneId").val();
        var ProdLineLeader = $("#ProdLineLeader").val();
        var ShiftLeader = $("#ShiftLeader").val();
        var VerifiedBy = $("#VerifiedBy").val();
        var CheckedBy = $("#CheckedBy").val();
        var ApprovedBy = $("#ApprovedBy").val();
        var AuditedBy = $("#AuditedBy").val();
        var ProdId = $("#ProdId").val();
        var OneS, TwoS, ThreeS, FourS, FiveS;

        if (LineId != 0 && ProjectId != 0 && BatchId != 0 && ZoneId != 0 && ProdLineLeader != "" && ShiftLeader != "" && VerifiedBy != "" && CheckedBy != "" && ApprovedBy != "" && AuditedBy != "" && ProdId != "") {

            table.find('tr').each(function (i) {
                var $tds = $(this).find('td');
                var RiskId = $tds.eq(0).text().trim();
                var StatusId, Namee, Image;

                if ($tds.length > 15) {
                    StatusId = $tds.eq(6).find('select').val();
                    Namee = $tds.eq(12).find('input').val();
                    Image = $tds.eq(15).find('input').val();
                } else {
                    StatusId = $tds.eq(4).find('select').val();
                    Namee = $tds.eq(10).find('input').val();
                    Image = $tds.eq(13).find('input').val();
                }

                // Check if ANY data is entered in the row (StatusId is enough)
                if (($('input[name="OneS"][id="' + RiskId + '"]').is(':checked')) || ($('input[name="TwoS"][id="' + RiskId + '"]').is(':checked')) || ($('input[name="ThreeS"][id="' + RiskId + '"]').is(':checked')) || ($('input[name="FourS"][id="' + RiskId + '"]').is(':checked')) || ($('input[name="FiveS"][id="' + RiskId + '"]').is(':checked'))) {  // Only StatusId is checked now.

                    OneS = $('input[name="OneS"][id="' + RiskId + '"]').is(':checked');
                    TwoS = $('input[name="TwoS"][id="' + RiskId + '"]').is(':checked');
                    ThreeS = $('input[name="ThreeS"][id="' + RiskId + '"]').is(':checked');
                    FourS = $('input[name="FourS"][id="' + RiskId + '"]').is(':checked');
                    FiveS = $('input[name="FiveS"][id="' + RiskId + '"]').is(':checked');

                    //if (StatusId == "") {
                    //    $tds.eq(StatusId === 6 ? 6 : 4).find('select').css("border", '1px solid red');
                    //    return;
                    //} else {
                    //    $tds.eq(StatusId === 6 ? 6 : 4).find('select').css("border", '');
                    //}

                    //if (Namee == "") {
                    //    $tds.eq(Namee === 12 ? 12 : 10).find('select').css("border", '1px solid red');
                    //    return;
                    //} else {
                    //    $tds.eq(Namee === 12 ? 12 : 10).find('select').css("border", '');
                    //}


                    //if (Image == "") {
                    //    $tds.eq(Image === 15 ? 15 : 13).find('input').css("border", '1px solid red');
                    //    return;
                    //} else {
                    //    $tds.eq(Image === 15 ? 15 : 13).find('input').css("border", '');
                    //}


                    CheckListResult.push({
                        'RiskId': RiskId,
                        'Namee': Namee, // Namee is always included, even if empty
                        "Image": Image,
                        "OneS": OneS,
                        "TwoS": TwoS,
                        "ThreeS": ThreeS,
                        "FourS": FourS,
                        "FiveS": FiveS
                    });
                } // End of data entered check

            }); // End of row loop

            if (CheckListResult.length > 0) {
                var reqListObj = {
                    ProdCheckListQualityAuditResults: CheckListResult,
                    LineId: LineId,
                    ProjectId: ProjectId,
                    BatchId: BatchId,
                    ZoneId: ZoneId,
                    ProdLineLeader: ProdLineLeader,
                    ShiftLeader: ShiftLeader,
                    VerifiedBy: VerifiedBy,
                    CheckedBy: CheckedBy,
                    ApprovedBy: ApprovedBy,
                    AuditedBy: AuditedBy,
                    ProdId: ProdId
                };

                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/CheckList/SaveProdQualityAuditChecklistWith5S",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                        window.location.reload();
                    },
                    error: function (error) {
                        console.error("AJAX Error:", error);
                        alert("Error saving data. Please check the console for details.");
                    }
                });
            } else {
                alert("No data to save.");
            }

        } else {
            alert("Please Select LineId and other mandatory fields.");
        }
    }



    function uploadFile(id) {
        debugger;
        if (window.FormData !== undefined) {
            var fileUpload = $("#FileUpload1-" + id).get(0);
            var files = fileUpload.files;
            if (files.length > 0) {
                // Create FormData object
                var fileData = new FormData();

                // Looping over all files and add it to FormData object
                for (var i = 0; i < files.length; i++) {
                    fileData.append(files[i].name, files[i]);
                }

                $.ajax({
                    url: '/CheckList/UploadDocument',
                    type: "POST",
                    contentType: false, // Not to set any content header
                    processData: false, // Not to process data
                    data: fileData,
                    success: function (result) {
                        //var id = $('#hdnDocId').val();
                        $('#Path-' + id).val(result);
                        $('#lblUploadStatus-' + id).show();
                        $('#btnUpload-' + id).css("display", "none");
                        $('#lblUploadStatu-' + id).text("Succesfully Uploaded");
                        $("#FileUpload1-" + id).val(null);
                        //$('#hdnDocId').val(" ");
                    },
                    error: function (err) {
                        alert(err.statusText);
                    }
                });
            } else {
                alert("Choose the File");

            }
        } else {
            alert("FormData is not supported.");
        }

    }

</script>