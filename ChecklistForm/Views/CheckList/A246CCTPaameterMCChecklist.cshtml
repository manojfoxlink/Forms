<script src="~/Scripts/jquery-ui-1.12.1.js"></script>
<link href="~/Content/jquery-ui-1.12.1.css" rel="stylesheet" />



<script>




    function Save() {
        //  var table = $("#QuastionTable");
        var CheckListResult = [];
        var fills = [];
        var i = 0;
        var J = 0;
        var k = 0;
        debugger;



        var table = $("table tbody");
        var formData = new FormData();
        var LineId = $("#LineId").val();
        var ProjectId = $("#ProjectId").val();
        var ProdLineLeader = $("#ProdLineLeader").val();
        var CheckedBy = $("#CheckedBy").val();
        var ApprovedBy = $("#ApprovedBy").val();
        var ModelId = $("#ModelId").val();
        var PartId = $("#PartId").val();
        if (LineId != 0 && ProjectId != 0 && ProdLineLeader != "" && CheckedBy != "" && ApprovedBy != "" && ModelId != "" && PartId != "") {

            table.find('tr').each(function (i) {
                var $tds = $(this).find('td'),
                    checkItemObservation = $tds.eq(8).find('input').val()
                if (typeof checkItemObservation != "undefined") {
                    //var ParameterId = $tds.eq(1).text().trim();
                    var LimitId = $tds.eq(0).text().trim();

                    var Value = $tds.eq(8).find('input').val();
                    if (Value != "") {
                        if (!$.isNumeric(Value)) {
                            $tds.eq(8).find('input').val("");
                            $('#' + LimitId).css("border", '1px solid red');
                        } else {
                            $('#' + LimitId).css("border", '1px solid green');
                        }
                    }


                } else {
                    //var ParameterId = $tds.eq(0).text().trim();
                    var LimitId = $tds.eq(0).text().trim();

                    var Value = $tds.eq(5).find('input').val();
                    if (Value != "") {
                        if (!$.isNumeric(Value)) {
                            $tds.eq(5).find('input').val("");
                            $('#' + LimitId).css("border", '1px solid red');
                        } else {
                            $('#' + LimitId).css("border", '1px solid green');
                        }
                    }



                }





                if ((LimitId != 0 && $.isNumeric(Value) == true)) {
                    CheckListResult[J] = {
                        'LimitId': LimitId, 'Value': Value
                    };
                    J++;
                }
                i++;
            });
            var reqListObj = new Object();
            reqListObj.A246CCTPaameterMCChecklist1Results = CheckListResult;
            reqListObj.LineId = LineId;
            reqListObj.ProjectId = ProjectId;
            reqListObj.ProdLineLeader = ProdLineLeader;
            reqListObj.CheckedBy = CheckedBy;
            reqListObj.ApprovedBy = ApprovedBy;
            reqListObj.ModelId = ModelId;
            reqListObj.PartId = PartId;
            if (CheckListResult.length > 0) {
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/CheckList/SaveA246CCTPaameterMCChecklist",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                          window.location.reload();
                        //$("#btnSave").click();
                    },
                    error: function () {
                        // alert('error');
                    }

                })
            }
            else {
                alert("Alteast one Part needed for Creating TO Request");
            }
        } else {
            alert("Please Select LineId");
        }
    }

    //$(document).ready(function () {
    //    debugger;

    //        var LineId = $("#LineId").val();

    //        if (LineId != 0)
    //        $("#btnSearch").click();

    //});

</script>





