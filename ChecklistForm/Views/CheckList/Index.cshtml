                            $('#' + ParameterId).css("border", '1px solid red');
                        } else {
                            $('#' + ParameterId).css("border", '1px solid green');
                        }
                    }



                }





                if ((Actual != "" && $.isNumeric(Actual) == true)) {
                    CheckListResult[J] = {
                        'ParameterId': ParameterId, 'LimitId': LimitedId, 'Actual': Actual
                    };
                    J++;
                }
                i++;
            });
            var reqListObj = new Object();
            reqListObj.CheckListResults = CheckListResult;
            reqListObj.LineId = LineId;
            reqListObj.ProjectId = ProjectId;
            reqListObj.ProdLineLeader = ProdLineLeader;
            reqListObj.CheckedBy = CheckedBy;
            reqListObj.ApprovedBy = ApprovedBy;
            reqListObj.ModelId = ModelId;
            reqListObj.PartId = PartId;
            if (CheckListResult.length > 0) {
                console.log(CheckListResult)
                //`LineId={LineId}`
                window.location.href = 'myapp://launch?all=' + encodeURIComponent(JSON.stringify(reqListObj));

                all: ['{"CheckListResults":[{"ParameterId":"1","LimitId":"1","Actual":"1111"}],"LineId":"1","ProjectId":"1","ProdLineLeader":"123","CheckedBy":"ww","ApprovedBy":"ff","ModelId":"1","PartId":"1"}']
                //$.ajax({
                //    type: "post",
                //    contentType: "application/json; charset=utf-8",
