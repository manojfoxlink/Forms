    function Save() {
        //  var table = $("#QuastionTable");
        var CheckListResult = [];
        var fills = [];
        var i = 0;
        var J = 0;
        var k = 0;
        debugger;



        var table = $("table tbody");
        var formData = new FormData();
        var LineId = $("#LineId").val();
        var ProjectId = $("#ProjectId").val();
        var ProdLineLeader = $("#ProdLineLeader").val();
        var CheckedBy = $("#CheckedBy").val();
        var ApprovedBy = $("#ApprovedBy").val();
        var ModelId = $("#ModelId").val();
        var PartId = $("#PartId").val();
        if (LineId != 0 && ProjectId != 0 && ProdLineLeader != "" && CheckedBy != "" && ApprovedBy != "" && ModelId != "" && PartId != "") {

            table.find('tr').each(function (i) {
                var $tds = $(this).find('td'),
                    checkItemObservation = $tds.eq(5).find('input').val()
                if (typeof checkItemObservation != "undefined") {
                    var InspectId = $tds.eq(0).text().trim();
                    var InspectorName = $tds.eq(3).find('input').val();
                    var InspectorId = $tds.eq(4).find('input').val();
                    var ActualValue = $tds.eq(5).find('input').val();

                    if (InspectorName != "") {
                        if (InspectorName == "") {
                            $tds.eq(3).find('input').val("");
                            $('#' + InspectId).css("border", '1px solid red');
                        } else {
                            $('#' + InspectId).css("border", '1px solid green');
                        }
                    }

                    if (InspectorId != "") {
                        if (InspectorId == "") {
                            $tds.eq(4).find('input').val("");
                            $('#' + InspectId).css("border", '1px solid red');
                        } else {
                            $('#' + InspectId).css("border", '1px solid green');
                        }
                    }

                    if (ActualValue != "") {
                        if (ActualValue == "") {
                            $tds.eq(5).find('input').val("");
                            $('#' + InspectId).css("border", '1px solid red');
                        } else {
                            $('#' + InspectId).css("border", '1px solid green');
                        }
                    }


                }






                if ((InspectId != 0 && InspectorName != "" && ActualValue != "" && InspectorId != "")) {
                    CheckListResult[J] = {
                        'InspectId': InspectId, 'ActualValue': ActualValue, 'InspectorName': InspectorName, 'InspectorId': InspectorId
                    };
                    J++;
                }
                i++;
            });
            var reqListObj = new Object();
            reqListObj.A246CPartToInspectCheckListResults = CheckListResult;
            reqListObj.LineId = LineId;
            reqListObj.ProjectId = ProjectId;
            reqListObj.ProdLineLeader = ProdLineLeader;
            reqListObj.CheckedBy = CheckedBy;
            reqListObj.ApprovedBy = ApprovedBy;
            reqListObj.ModelId = ModelId;
            reqListObj.PartId = PartId;
            if (CheckListResult.length > 0) {
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/CheckList/SaveA246CPartToInspect",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                    window.location.reload();
