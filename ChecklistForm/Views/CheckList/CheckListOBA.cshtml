                        'CableSerialNo': CableSerialNo, 'CableId': CableId, 'SRId': SRId, 'PlugId': PlugId, 'PlugShellId': PlugShellId, 'BootId': BootId, 'BoottId': BoottId, 'FacePlateId': FacePlateId, 'FaceePlateId': FaceePlateId, 'Remark': Remark, 'CollarId': CollarId
                    };
                    J++;
                }
                i++;
            });
            var reqListObj = new Object();
            reqListObj.CheckListOBAResults = CheckListResult;
            reqListObj.LineId = LineId;
            reqListObj.ProjectId = ProjectId;
            reqListObj.BoxNo = BoxNo;
            reqListObj.PalletNo = PalletNo;
            reqListObj.ProdLineLeader = ProdLineLeader;
            reqListObj.CheckedBy = CheckedBy;
            reqListObj.ApprovedBy = ApprovedBy;
            reqListObj.ModelId = ModelId;
            reqListObj.PartId = PartId;
            if (CheckListResult.length > 0) {
                $.ajax({
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    url: "/CheckList/SaveCheckOBA",
                    data: JSON.stringify(reqListObj),
                    success: function (data) {
                        window.location.reload();
                        //$("#btnSearch").click();
                    },
                    error: function () {
                        // alert('error');
                    }

                })
            }
            else {
                alert("Alteast one Part needed for Creating TO Request");
            }
        } else {
            alert("Please Select LineId");
        }
    }

</script>
