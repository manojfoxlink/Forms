<script src="~/Scripts/jquery-ui-1.12.1.js"></script>
<link href="~/Content/jquery-ui-1.12.1.css" rel="stylesheet" />



<script>

    function Save() {
        var CheckListResult = [];

        var table = $("table tbody");
        debugger;
        table.find('tr').each(function (i) {
            var $tds = $(this).find('td');
            var ResultId = $tds.eq(0).text().trim();
            var Image, Descrription, RootCausee, CorrectiveAction, PreventiveAction;
             debugger;
            if ($tds.length > 11) {
                debugger;
                RootCausee = $tds.eq(8).find('input').val();
                CorrectiveAction = $tds.eq(9).find('input').val();
                PreventiveAction = $tds.eq(10).find('input').val();
            }

            // Ensure BOTH Description and Image have data before adding to the array
            if (ResultId && RootCausee && PreventiveAction && CorrectiveAction) { // Modified condition
                CheckListResult.push({
                    ResultId: ResultId,
                    RootCausee: RootCausee,
                    PreventiveAction: PreventiveAction,
                    CorrectiveAction: CorrectiveAction
                });
            }
        }); // End of row loop

        if (CheckListResult.length > 0) {
            var reqListObj = {
                CheckListXBarResults: CheckListResult,
            };

            $.ajax({
                type: "POST",
                contentType: "application/json; charset=utf-8",
                url: "/CheckList/SaveFACAXBarChecklist",
                data: JSON.stringify(reqListObj),
                success: function (data) {
                    window.location.reload();
                },
                error: function (error) {
                    console.error("AJAX Error:", error);
                    alert("Error saving data. Please check the console for details.");
                }
            });
        } else {
            alert("No data to save.");
        }
    }


    function uploadFile(id) {
        //debugger;
        if (window.FormData !== undefined) {
            var fileUpload = $("#FileUpload1-" + id).get(0);
            var files = fileUpload.files;
            if (files.length > 0) {
                // Create FormData object
                var fileData = new FormData();

                // Looping over all files and add it to FormData object
                for (var i = 0; i < files.length; i++) {
                    fileData.append(files[i].name, files[i]);
                }

                $.ajax({
                    url: '/CheckList/UploadDocument',
                    type: "POST",
                    contentType: false, // Not to set any content header
                    processData: false, // Not to process data
                    data: fileData,
                    success: function (result) {
                        //var id = $('#hdnDocId').val();
                        $('#Path-' + id).val(result);
                        $('#lblUploadStatus-' + id).show();
                        $('#btnUpload-' + id).css("display", "none");
                        $('#lblUploadStatu-' + id).text("Succesfully Uploaded");
                        $("#FileUpload1-" + id).val(null);
                        //$('#hdnDocId').val(" ");
                    },
                    error: function (err) {
                        alert(err.statusText);
                    }
                });
            } else {
                alert("Choose the File");

            }
        } else {
            alert("FormData is not supported.");
        }

    }

</script>