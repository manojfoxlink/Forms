@model ChecklistForm.Models.NativeValidationViewModel
@{
    ViewBag.Title = "NativeValidation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    Html.RenderPartial("_ErrorMessage");
}
@using (Html.BeginForm("NativeValidation", "Master", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true)

    <div class="box box-solid box-warning">
        <div class="box-header">
            @*<h3 class="box-title">Create New ID</h3>*@
            <div class="box-tools pull-right">
                <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                    <i class="fa fa-minus"></i>
                </button>
            </div>
        </div><!-- /.box-header -->
        <div class="box-body">

            <div class="register-box">
                <div class="register-logo">
                    @*<a href="../Home/Index"><b>Create a NEW Project</b>User</a>*@
                    <a href="#"><b>NativeValidation</b></a>
                </div>
                <div class="row">


                </div>
                <div class="register-box-body">
                    @*<p class="login-box-msg">Register a new membership</p>*@

                    <form action=".." method="post">


                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(model => model.StationId, new SelectList(Model.Stations, "StationId", "StationName", 0), "Select Station", new { @class = "form-control select2", @style = "width: 100%", onchange = "ddlStationsChanged()", required = "required" })<br />
                            @Html.ValidationMessageFor(model => model.StationId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>

                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(model => model.InspectId, new SelectList(Model.Inpections, "InspectId", "Inspection", 0), "Select Inspection", new { @class = "form-control select2", @style = "width: 100%", onchange = "ddlInspectChanged()", required = "required" })<br />
                            @Html.ValidationMessageFor(model => model.InspectId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>

                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(model => model.FreqId, new SelectList(Model.Frequencies, "FreqId", "Frequency", 0), "Select Frequency", new { @class = "form-control select2", @style = "width: 100%", onchange = "ddlFrequencyChanged()", required = "required" })<br />
                            @Html.ValidationMessageFor(model => model.FreqId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>

                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(model => model.PeriodId, new SelectList(Model.Periodss, "PeriodId", "Periods", 0), "Select Period", new { @class = "form-control select2", @style = "width: 100%", required = "required" })<br />
                            @Html.ValidationMessageFor(model => model.PeriodId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>

                        </div>

                        <div class="row">
                            <div class="col-xs-4">

                            </div>
                            <div class="col-xs-4">
                                <button type="submit" class="btn btn-success btn-block btn-flat">Create</button>
                            </div>
                            @*<div class="col-xs-4">
                                    <button type="submit" class="btn btn-success btn-block btn-flat">Search</button>
                                </div>
                                <div class="col-xs-4">
                                    <button type="submit" class="btn btn-success btn-block btn-flat">Update</button>
                                </div>*@
                            <!-- /.col -->
                            <div class="col-xs-4">

                            </div>
                            <!-- /.col -->
                        </div>
                        <div class="row">
                            <div class="col-xs-2">

                            </div>
                            <div class="col-xs-8">
                                <h3 class="text-danger">@ViewBag.ResultMessage</h3>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-2">

                            </div>
                            <!-- /.col -->
                        </div>
                    </form>




                </div>
                <!-- /.form-box -->
            </div>
        </div><!-- /.box-body -->
    </div>

}

