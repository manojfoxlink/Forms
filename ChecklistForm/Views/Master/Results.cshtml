@model ChecklistForm.Models.ResultsViewModel
@{
    ViewBag.Title = "Results";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Results</h2>

@using (Html.BeginForm("Results", "Master", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary( true )
    <div class ="box box-solid box-warning ">
        <div class="box-body">
            <div class="register-box-body">
                <fieldset>
                    <form action=".." method="post">
                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.LowerLimit, new { placeholder = "Lower Limit", @class = "form-control", autocomplete = "off" })
                            @Html.ValidationMessageFor(model => model.LowerLimit, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                            <br />

                        </div>
                        <div>
                            @Html.TextBoxFor(x => x.UpperLimit, new { placeholder = "Upper Limit", @class = "form-control", autocomplete = "off" })
                            @Html.ValidationMessageFor(model => model.UpperLimit, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                            <br />
                        </div>
                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(x => x.ProjectId, new SelectList(Model.Projects, "ProjectId", "ProjectName", 0), "--select--")
                             @Html.ValidationMessageFor(model => model.ProjectId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                            <br />
                        </div>
                        <div>
                            @Html.DropDownListFor(x => x.StationId, new SelectList(Model.Stations, "StationId", "StationName", 0), "--select--")
                             @Html.ValidationMessageFor(model => model.StationId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                            <br />
                        </div>
                        <div class="form-group has-feedback">
                            @Html.DropDownListFor(x => x.SubStationId, new SelectList(Model.SubStations, "SubStationId", "SubStationName", 0), "--select--")
                             @Html.ValidationMessageFor(model => model.SubStationId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                            <br />
                        </div>
                        <div>
                            @Html.DropDownListFor(x => x.ParameterId, new SelectList(Model.Parameters, "ParameterId", "ParameterName", 0), "--select--") <br />
                            @Html.ValidationMessageFor(model => model.ParameterId, "", new { @class = "text-danger" })
                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>
                        </form>
                </fieldset>
            </div>
            <p>
                <button type="submit" value="submit" class="btn btn-success">SAVE</button>
            </p>
        </div>
    </div>
}
