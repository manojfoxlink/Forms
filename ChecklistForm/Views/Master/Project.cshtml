@model ChecklistForm.Models.ProjectViewModel
@{
    ViewBag.Title = "Project";
    Layout = "~/Views/Shared/_Layout.cshtml";
   
}

@{
    Html.RenderPartial("_ErrorMessage");
}
@using (Html.BeginForm("Project", "Master", FormMethod.Post, new { enctype = "multipart/form-data", @class = "form-horizontal", role = "form" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true)
    
 

    <div class="box box-solid box-warning">
        <div class="box-header">
            @*<h3 class="box-title">Create New ID</h3>*@
            <div class="box-tools pull-right">
                <button type="button" class="btn btn-box-tool" data-widget="collapse" data-toggle="tooltip" title="Collapse">
                    <i class="fa fa-minus"></i>
                </button>
            </div>
        </div><!-- /.box-header -->
        <div class="box-body">

            <div class="register-box">
                <div class="register-logo">
                   
                    <a href="#"><b>Project Creation</b></a>
                </div>
                <div class="row">

                </div>
                <div class="register-box-body">
                    

                    <form action=".." method="post">
                        <div class="form-group has-feedback">
                            @Html.TextBoxFor(x => x.ProjectName, new { placeholder = "project Name", @class = "form-control", autocomplete = "off" })
                            @Html.ValidationMessageFor(model => model.ProjectName, "", new { @class = "text-danger" })

                            <span class="glyphicon glyphicon-user form-control-feedback"></span>
                        </div>
                       
                        <div class="row">
                            <div class="col-xs-4">

                            </div>
                            <div class="col-xs-4">
                                <button type="submit" class="btn btn-success btn-block btn-flat">Submit</button>
                            </div>
                          
                            <div class="col-xs-4">

                            </div>
                            <!-- /.col -->
                        </div>
                        <div class="row">
                            <div class="col-xs-2">

                            </div>
                            <div class="col-xs-8">
                                <h3 class="text-danger">@ViewBag.ResultMessage</h3>
                            </div>
                            <!-- /.col -->
                            <div class="col-xs-2">

                            </div>
                            <!-- /.col -->
                        </div>
                    </form>

                    


                </div>
                <!-- /.form-box -->
            </div>
        </div><!-- /.box-body -->
    </div>
 
    <script>

    </script>






}
@*<div>
    @Html.ActionLink("Back to List", "Index")
</div>*@